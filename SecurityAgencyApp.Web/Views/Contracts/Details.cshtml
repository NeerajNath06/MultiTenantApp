@{
    ViewData["Title"] = "Contract Details";
    var contractId = ViewBag.ContractId;
}

<div id="contractDetailsPage"
     data-contract-id="@contractId"
     data-load-endpoint="Contracts/@contractId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Contract Details</h1>
            <p class="page-subtitle mb-0">View contract information</p>
        </div>
        <div>
            <a href="@Url.Action("Edit", new { id = contractId })" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <button type="button" id="contractDeleteButton" class="btn btn-outline-danger">
                <i class="fas fa-trash me-2"></i>Delete
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-file-contract"></i>Contract Information</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Contract Number</label>
                        <p class="mb-0"><strong data-field="contractNumber">-</strong></p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Client</label>
                        <p class="mb-0" data-field="clientName">-</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Title</label>
                        <p class="mb-0" data-field="title">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Start Date</label>
                        <p class="mb-0" data-field="startDate">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">End Date</label>
                        <p class="mb-0" data-field="endDate">-</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Contract Value</label>
                        <p class="mb-0"><strong data-field="contractValue">-</strong></p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Monthly Amount</label>
                        <p class="mb-0" data-field="monthlyAmount">-</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Billing Cycle</label>
                        <p class="mb-0" data-field="billingCycle">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Status</label>
                        <p class="mb-0">
                            <span class="badge bg-secondary" data-field="statusBadge">-</span>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Number of Guards</label>
                        <p class="mb-0" data-field="numberOfGuards">-</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Description</label>
                        <p class="mb-0" data-field="description">-</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Payment Terms</label>
                        <p class="mb-0" data-field="paymentTerms">-</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm enterprise-details-card mt-4">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-map-marked-alt"></i>Contract Sites</h5>
                <div id="contractSitesWrapper"></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-info-circle"></i>Additional Information</h5>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Created Date</label>
                    <p class="mb-0" data-field="createdDate">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Auto Renewal</label>
                    <p class="mb-0">
                        <span class="badge bg-secondary" data-field="autoRenewalBadge">-</span>
                    </p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Renewal Date</label>
                    <p class="mb-0" data-field="renewalDate">-</p>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/contracts/details.js" asp-append-version="true"></script>
}
