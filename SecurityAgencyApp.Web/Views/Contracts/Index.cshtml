@{
    ViewData["Title"] = "Contracts Management";
}

<div id="contractsIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-details-base="@Url.Action("Details", new { id = "__id__" })"
     data-edit-base="@Url.Action("Edit", new { id = "__id__" })">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Contracts</h1>
            <p class="page-subtitle mb-0">Manage client contracts</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-file-contract me-2"></i>Create New Contract
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Contracts</div>
                    <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Contracts</div>
                    <div class="stat-value" data-stat="active">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Expired Contracts</div>
                    <div class="stat-value" data-stat="expired">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search &amp; Filters</h5>
    </div>
    <div class="card-body">
        <form id="contractsFilterForm" class="row g-3 form">
            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="10" />
            <div class="col-md-4">
                <input type="text" id="contractsSearch" name="search" class="form-control" placeholder="Search contract number, title..." />
            </div>
            <div class="col-md-4">
                <select id="contractsClientId" name="clientId" class="form-select">
                    <option value="">All Clients</option>
                </select>
            </div>
            <div class="col-md-3">
                <select id="contractsStatus" name="status" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="Draft">Draft</option>
                    <option value="Active">Active</option>
                    <option value="Expired">Expired</option>
                    <option value="Terminated">Terminated</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search"></i></button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-file-contract me-2 text-primary"></i>Contract Directory</h5>
        <span id="contractsRecordCount" class="text-muted small">0 total records</span>
    </div>
    <div class="card-body">
        <div id="contractsTableWrapper"></div>
        <div id="contractsPaginationContainer" class="mt-4 d-none">
            <div id="contractsPaginationSummary" class="text-muted text-center small mb-2"></div>
            <ul id="contractsPagination" class="pagination justify-content-center"></ul>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/contracts/index.js" asp-append-version="true"></script>
}
