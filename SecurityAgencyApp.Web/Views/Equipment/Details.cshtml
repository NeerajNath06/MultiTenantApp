@{
    ViewData["Title"] = "Equipment Details";
}

<div id="equipmentDetailsPage"
     data-equipment-id="@ViewBag.EquipmentId"
     data-load-endpoint="Equipment/@ViewBag.EquipmentId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Equipment Details</h1>
            <p class="page-subtitle mb-0"><span data-field="equipmentCode">-</span> - <span data-field="equipmentName">-</span></p>
        </div>
        <div>
            <button id="equipmentDeleteButton" type="button" class="btn btn-outline-danger">
                <i class="fas fa-trash me-2"></i>Delete
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm enterprise-details-card">
    <div class="card-body">
        <h5 class="section-title"><i class="fas fa-toolbox"></i>Equipment Information</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Equipment Code</label>
                <p class="mb-0"><strong data-field="equipmentCode">-</strong></p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Equipment Name</label>
                <p class="mb-0" data-field="equipmentName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Category</label>
                <p class="mb-0" data-field="category">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Status</label>
                <p class="mb-0">
                    <span data-field="statusBadge" class="badge bg-secondary">-</span>
                </p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Manufacturer</label>
                <p class="mb-0" data-field="manufacturer">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Model Number</label>
                <p class="mb-0" data-field="modelNumber">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Serial Number</label>
                <p class="mb-0" data-field="serialNumber">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Purchase Date</label>
                <p class="mb-0" data-field="purchaseDate">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Purchase Cost</label>
                <p class="mb-0" data-field="purchaseCost">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Assigned to Guard</label>
                <p class="mb-0" data-field="assignedToGuardName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Assigned to Site</label>
                <p class="mb-0" data-field="assignedToSiteName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Next Maintenance</label>
                <p class="mb-0" data-field="nextMaintenanceDate">-</p>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold text-muted">Notes</label>
                <p class="mb-0" data-field="notes">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Created Date</label>
                <p class="mb-0" data-field="createdDate">-</p>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/equipment/details.js" asp-append-version="true"></script>
}
