@model SecurityAgencyApp.Web.Models.Api.IncidentDetailDto
@{
    ViewData["Title"] = "Incident Details";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Incident Details</h1>
            <p class="page-subtitle mb-0">@Model.IncidentNumber</p>
        </div>
        <div>
            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <form asp-action="Delete" method="post" class="d-inline" data-confirm-message="Are you sure you want to delete (close) this incident?">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger">
                    <i class="fas fa-trash me-2"></i>Delete
                </button>
            </form>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5 class="card-title mb-4">Incident Information</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Incident Number</label>
                <p class="mb-0"><strong>@Model.IncidentNumber</strong></p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Date</label>
                <p class="mb-0">@Model.IncidentDate.ToString("dd MMM yyyy HH:mm")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Site</label>
                <p class="mb-0">@Model.SiteName</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Guard</label>
                <p class="mb-0">@(Model.GuardName ?? "-")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Type</label>
                <p class="mb-0">@Model.IncidentType</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Severity</label>
                <p class="mb-0">
                    <span class="badge bg-@(Model.Severity == "Critical" ? "danger" : Model.Severity == "High" ? "warning" : Model.Severity == "Medium" ? "info" : "secondary")">@Model.Severity</span>
                </p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Status</label>
                <p class="mb-0">
                    <span class="badge bg-@(Model.Status == "Open" ? "danger" : Model.Status == "InProgress" ? "warning" : Model.Status == "Resolved" ? "success" : "secondary")">@Model.Status</span>
                </p>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold text-muted">Description</label>
                <p class="mb-0">@Model.Description</p>
            </div>
            @if (!string.IsNullOrEmpty(Model.ActionTaken))
            {
                <div class="col-12">
                    <label class="form-label fw-semibold text-muted">Action Taken</label>
                    <p class="mb-0">@Model.ActionTaken</p>
                </div>
            }
        </div>
    </div>
</div>
