@{
    ViewData["Title"] = "Leave Request Details";
}

<div id="leaveRequestDetailsPage"
     data-leave-request-id="@ViewBag.LeaveRequestId"
     data-load-endpoint="LeaveRequests/@ViewBag.LeaveRequestId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Leave Request Details</h1>
            <p class="page-subtitle mb-0"><span data-field="guardCode">-</span> - <span data-field="leaveType">-</span></p>
        </div>
        <div>
            <button id="leaveRequestDeleteButton" type="button" class="btn btn-outline-danger">
                <i class="fas fa-trash me-2"></i>Delete
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm enterprise-details-card">
    <div class="card-body">
        <h5 class="section-title"><i class="fas fa-calendar-minus"></i>Leave Information</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Guard</label>
                <p class="mb-0"><strong data-field="guardCode">-</strong> - <span data-field="guardName">-</span></p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Leave Type</label>
                <p class="mb-0" data-field="leaveType">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Start Date</label>
                <p class="mb-0" data-field="startDate">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">End Date</label>
                <p class="mb-0" data-field="endDate">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Total Days</label>
                <p class="mb-0"><strong data-field="totalDays">-</strong></p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Status</label>
                <p class="mb-0">
                    <span data-field="statusBadge" class="badge bg-secondary">-</span>
                </p>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold text-muted">Reason</label>
                <p class="mb-0" data-field="reason">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Notes</label>
                <p class="mb-0" data-field="notes">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Approved Date</label>
                <p class="mb-0" data-field="approvedDate">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Approved By</label>
                <p class="mb-0" data-field="approvedByName">-</p>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold text-muted">Rejection Reason</label>
                <p class="mb-0" data-field="rejectionReason">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Created Date</label>
                <p class="mb-0" data-field="createdDate">-</p>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/leave-requests/details.js" asp-append-version="true"></script>
}
