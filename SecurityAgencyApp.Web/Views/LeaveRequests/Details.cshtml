@model SecurityAgencyApp.Web.Models.Api.LeaveRequestDetailDto
@{
    ViewData["Title"] = "Leave Request Details";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Leave Request Details</h1>
            <p class="page-subtitle mb-0">@Model.GuardCode - @Model.LeaveType</p>
        </div>
        <div>
            <form asp-action="Delete" method="post" class="d-inline" data-confirm-message="Are you sure you want to delete (cancel) this leave request?">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger">
                    <i class="fas fa-trash me-2"></i>Delete
                </button>
            </form>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm enterprise-details-card">
    <div class="card-body">
        <h5 class="section-title"><i class="fas fa-calendar-minus"></i>Leave Information</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Guard</label>
                <p class="mb-0"><strong>@Model.GuardCode</strong> - @Model.GuardName</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Leave Type</label>
                <p class="mb-0">@Model.LeaveType</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Start Date</label>
                <p class="mb-0">@Model.StartDate.ToString("dd MMM yyyy")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">End Date</label>
                <p class="mb-0">@Model.EndDate.ToString("dd MMM yyyy")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Total Days</label>
                <p class="mb-0"><strong>@Model.TotalDays</strong></p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Status</label>
                <p class="mb-0">
                    <span class="badge bg-@(Model.Status == "Approved" ? "success" : Model.Status == "Rejected" || Model.Status == "Cancelled" ? "danger" : "warning")">@Model.Status</span>
                </p>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold text-muted">Reason</label>
                <p class="mb-0">@Model.Reason</p>
            </div>
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="col-12">
                    <label class="form-label fw-semibold text-muted">Notes</label>
                    <p class="mb-0">@Model.Notes</p>
                </div>
            }
            @if (Model.ApprovedDate.HasValue)
            {
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Approved Date</label>
                    <p class="mb-0">@Model.ApprovedDate.Value.ToString("dd MMM yyyy HH:mm")</p>
                </div>
                @if (!string.IsNullOrEmpty(Model.ApprovedByName))
                {
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Approved By</label>
                        <p class="mb-0">@Model.ApprovedByName</p>
                    </div>
                }
            }
            @if (!string.IsNullOrEmpty(Model.RejectionReason))
            {
                <div class="col-12">
                    <label class="form-label fw-semibold text-muted">Rejection Reason</label>
                    <p class="mb-0">@Model.RejectionReason</p>
                </div>
            }
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Created Date</label>
                <p class="mb-0">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</p>
            </div>
        </div>
    </div>
</div>
