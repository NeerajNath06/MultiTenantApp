@{
    ViewData["Title"] = "Leave Requests";
}

<div id="leaveRequestsIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-details-base="@Url.Action("Details", new { id = "__id__" })">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Leave Requests</h1>
            <p class="page-subtitle mb-0">Manage guard leave requests</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-calendar-times me-2"></i>New Leave Request
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Requests</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Approved</div>
                <div class="stat-value" data-stat="approved">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Pending</div>
                <div class="stat-value" data-stat="pending">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-calendar-times me-2 text-primary"></i>Leave Directory</h5>
        <span id="leaveRequestsRecordCount" class="text-muted small">0 total records</span>
    </div>
    <div class="card-body">
        <div id="leaveRequestsTableWrapper"></div>
        <div id="leaveRequestsPaginationContainer" class="d-none mt-4">
            <div id="leaveRequestsPaginationSummary" class="text-muted small mb-2"></div>
            <ul id="leaveRequestsPagination" class="pagination justify-content-center mb-0"></ul>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/leave-requests/index.js" asp-append-version="true"></script>
}
