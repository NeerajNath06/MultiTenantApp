@{
    ViewData["Title"] = "Vehicle Log Details";
}

<div id="vehicleDetailsPage"
     data-vehicle-log-id="@ViewBag.VehicleLogId"
     data-load-endpoint="Vehicles/@ViewBag.VehicleLogId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Vehicle Log Details</h1>
            <p class="page-subtitle mb-0"><span data-field="vehicleNumber">-</span> · <span data-field="vehicleType">-</span></p>
        </div>
        <div>
            <button id="vehicleDeleteButton" type="button" class="btn btn-outline-danger"><i class="fas fa-trash me-2"></i>Delete</button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Back to List</a>
            <button id="vehicleExitButton" type="button" class="btn btn-success d-none"><i class="fas fa-sign-out-alt me-2"></i>Record Exit</button>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm enterprise-details-card">
    <div class="card-body">
        <h5 class="section-title"><i class="fas fa-truck"></i>Vehicle Log Information</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label text-muted small">Vehicle Number</label>
                <p class="fw-semibold mb-0" data-field="vehicleNumber">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small">Vehicle Type</label>
                <p class="fw-semibold mb-0" data-field="vehicleType">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small">Driver Name</label>
                <p class="fw-semibold mb-0" data-field="driverName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small">Driver Phone</label>
                <p class="fw-semibold mb-0" data-field="driverPhone">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small">Purpose</label>
                <p class="fw-semibold mb-0" data-field="purpose">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small">Parking Slot</label>
                <p class="fw-semibold mb-0" data-field="parkingSlot">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small">Site</label>
                <p class="fw-semibold mb-0" data-field="siteName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small">Registering Guard</label>
                <p class="fw-semibold mb-0" data-field="guardName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small">Entry Time</label>
                <p class="fw-semibold mb-0" data-field="entryTime">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small">Exit Time</label>
                <p class="fw-semibold mb-0" data-field="exitTime">-</p>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/vehicles/details.js" asp-append-version="true"></script>
}
