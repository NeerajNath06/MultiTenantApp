@{
    ViewData["Title"] = "Vehicle Log Summary by Site";
}

<div id="vehicleSummaryPage"
     data-index-url="@Url.Action("Index")"
     data-summary-endpoint="Vehicles/summary">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Vehicle Log Summary by Site</h1>
            <p class="page-subtitle mb-0">Total, inside, and exited counts per site</p>
        </div>
        <a href="@Url.Action("Index")" class="btn btn-outline-primary"><i class="fas fa-list me-2"></i>View All Logs</a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form id="vehicleSummaryFilterForm" method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Site</label>
                <select id="vehicleSummarySiteId" name="siteId" class="form-select">
                    <option value="">All Sites</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">From Date</label>
                <input type="date" name="dateFrom" class="form-control" value="@ViewContext.HttpContext.Request.Query["dateFrom"]" />
            </div>
            <div class="col-md-3">
                <label class="form-label">To Date</label>
                <input type="date" name="dateTo" class="form-control" value="@ViewContext.HttpContext.Request.Query["dateTo"]" />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary"><i class="fas fa-filter me-2"></i>Apply</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div id="vehicleSummaryTableWrapper"></div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/vehicles/summary.js" asp-append-version="true"></script>
}
