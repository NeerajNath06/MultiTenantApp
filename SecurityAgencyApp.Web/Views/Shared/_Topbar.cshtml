@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
    var tenantName = Context.Session.GetString("TenantName") ?? "Security Agency";
    var userFullName = Context.Session.GetString("UserFullName") ?? "User";
    var userEmail = Context.Session.GetString("UserEmail") ?? "";
    var userInitial = (userFullName.Length > 0 ? userFullName.Substring(0, 1) : "U").ToUpperInvariant();
}
<div class="topbar">
    <div class="topbar-left">
        <button type="button" class="btn btn-sidebar-toggle" id="btnSidebarToggle" aria-label="Toggle sidebar">
            <i class="fas fa-bars"></i>
        </button>
        <button type="button" class="btn btn-sidebar-collapse d-none d-lg-inline-flex" id="btnSidebarCollapse" aria-label="Collapse sidebar" title="Collapse sidebar">
            <i class="fas fa-chevron-left"></i>
        </button>
        <div class="topbar-title d-none d-md-block">
            <h5 class="topbar-page-title mb-0">@pageTitle</h5>
            <small class="topbar-subtitle">@tenantName</small>
        </div>
        <div class="topbar-search flex-grow-1 d-none d-lg-block" style="max-width: 400px;">
            <div class="search-input-wrap">
                <i class="fas fa-search search-icon"></i>
                <input type="search" class="form-control search-input" placeholder="Search..." aria-label="Search" id="topbarSearch" />
            </div>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-actions d-flex align-items-center gap-1">
            <div class="dropdown topbar-quick-actions d-none d-md-block">
                <button class="btn btn-primary btn-sm dropdown-toggle" type="button" id="quickActionsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-plus me-1"></i>New
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg" aria-labelledby="quickActionsDropdown">
                    <li><a class="dropdown-item" href="@Url.Action("Create", "Clients")"><i class="fas fa-building me-2"></i>New Client</a></li>
                    <li><a class="dropdown-item" href="@Url.Action("Create", "Users")"><i class="fas fa-user-plus me-2"></i>New User</a></li>
                    <li><a class="dropdown-item" href="@Url.Action("Create", "Contracts")"><i class="fas fa-file-contract me-2"></i>New Contract</a></li>
                    <li><hr class="dropdown-divider" /></li>
                    <li><a class="dropdown-item" href="@Url.Action("Create", "SecurityGuards")"><i class="fas fa-shield-alt me-2"></i>New Guard</a></li>
                    <li><a class="dropdown-item" href="@Url.Action("Create", "Sites")"><i class="fas fa-map-marker-alt me-2"></i>New Site</a></li>
                </ul>
            </div>
            <button type="button" class="btn btn-icon btn-ghost theme-toggle" id="themeToggle" aria-label="Toggle theme" title="Toggle light/dark theme">
                <i class="fas fa-moon theme-icon-dark"></i>
                <i class="fas fa-sun theme-icon-light d-none"></i>
            </button>
            <div class="dropdown topbar-notifications">
                <button class="btn btn-icon btn-ghost" type="button" id="notificationsDropdown" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Notifications">
                    <i class="fas fa-bell"></i>
                    <span class="topbar-badge">3</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end dropdown-notifications" aria-labelledby="notificationsDropdown">
                    <li class="dropdown-header d-flex justify-content-between align-items-center">
                        <span class="fw-semibold">Notifications</span>
                        <a href="@Url.Action("Index", "Notifications")" class="btn btn-sm btn-link p-0">View all</a>
                    </li>
                    <li><hr class="dropdown-divider" /></li>
                    <li>
                        <a class="dropdown-item py-3" href="#">
                            <div class="d-flex gap-2">
                                <div class="flex-shrink-0 notification-icon notification-icon-success">
                                    <i class="fas fa-user-plus small"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold small">New user registered</div>
                                    <small class="text-muted">2 minutes ago</small>
                                </div>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-3" href="#">
                            <div class="d-flex gap-2">
                                <div class="flex-shrink-0 notification-icon notification-icon-primary">
                                    <i class="fas fa-file-contract small"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold small">Contract expiring soon</div>
                                    <small class="text-muted">1 hour ago</small>
                                </div>
                            </div>
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-3" href="#">
                            <div class="d-flex gap-2">
                                <div class="flex-shrink-0 notification-icon notification-icon-warning">
                                    <i class="fas fa-exclamation-triangle small"></i>
                                </div>
                                <div>
                                    <div class="fw-semibold small">Pending approval</div>
                                    <small class="text-muted">3 hours ago</small>
                                </div>
                            </div>
                        </a>
                    </li>
                    <li><hr class="dropdown-divider" /></li>
                    <li><a class="dropdown-item text-center text-muted small" href="@Url.Action("Index", "Notifications")">Mark all as read</a></li>
                </ul>
            </div>
            <div class="dropdown topbar-user">
                <button class="btn btn-user-menu" type="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="user-avatar" title="@userFullName">@userInitial</span>
                    <div class="user-meta d-none d-lg-block text-start">
                        <span class="user-name">@userFullName</span>
                        <span class="user-email text-muted small d-block">@userEmail</span>
                    </div>
                    <i class="fas fa-chevron-down ms-2 text-muted small dropdown-chevron"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end dropdown-user" aria-labelledby="userMenuDropdown">
                    <li class="dropdown-header">
                        <div class="fw-semibold">@userFullName</div>
                        <small class="text-muted">@userEmail</small>
                    </li>
                    <li><hr class="dropdown-divider" /></li>
                    <li><a class="dropdown-item" href="@Url.Action("Index", "CompanyProfile")"><i class="fas fa-building me-2"></i>Company Profile</a></li>
                    <li><a class="dropdown-item" href="#"><i class="fas fa-cog me-2"></i>Settings</a></li>
                    <li><hr class="dropdown-divider" /></li>
                    <li>
                        <form method="post" action="@Url.Action("Logout", "Auth")" class="dropdown-item p-0">
                            <button type="submit" class="btn btn-link text-danger w-100 text-start p-0 border-0">
                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
<script>
    (function () {
        var toggle = document.getElementById('themeToggle');
        if (toggle) {
            toggle.addEventListener('click', function () {
                var html = document.documentElement;
                var isDark = html.getAttribute('data-theme') === 'dark';
                var next = isDark ? 'light' : 'dark';
                if (window.setAppTheme) window.setAppTheme(next);
                var iconDark = toggle.querySelector('.theme-icon-dark');
                var iconLight = toggle.querySelector('.theme-icon-light');
                if (iconDark && iconLight) {
                    iconDark.classList.toggle('d-none', next === 'dark');
                    iconLight.classList.toggle('d-none', next === 'light');
                }
            });
            document.addEventListener('DOMContentLoaded', function () {
                var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                var iconDark = toggle.querySelector('.theme-icon-dark');
                var iconLight = toggle.querySelector('.theme-icon-light');
                if (iconDark && iconLight) {
                    iconDark.classList.toggle('d-none', isDark);
                    iconLight.classList.toggle('d-none', !isDark);
                }
            });
        }
    })();
</script>
