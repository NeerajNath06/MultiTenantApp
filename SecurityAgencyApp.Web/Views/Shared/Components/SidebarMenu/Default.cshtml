@model IEnumerable<SecurityAgencyApp.Web.Models.Api.MenuDto>
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    static string GetControllerName(string? route)
    {
        if (string.IsNullOrWhiteSpace(route) || route == "#") return string.Empty;
        var parts = route.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 1 ? parts[0] : route;
    }

    string ResolveUrl(string? route)
    {
        if (string.IsNullOrWhiteSpace(route) || route == "#") return "#";
        var parts = route.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return Url.Action(parts[1], parts[0]) ?? "#";
        }
        return Url.Action("Index", parts[0]) ?? "#";
    }
}
@if (Model == null || !Model.Any())
{
    <a href="@Url.Action("Index", "Home")" class="menu-item active">
        <i class="fas fa-home"></i>
        <span>Dashboard</span>
    </a>
}

@foreach (var menu in Model ?? Enumerable.Empty<SecurityAgencyApp.Web.Models.Api.MenuDto>())
{
    if (!menu.IsActive) { continue; }
    var hasSubMenus = menu.SubMenus != null && menu.SubMenus.Any(s => s.IsActive);
    if (hasSubMenus)
    {
        var menuId = "menu-" + menu.Id.ToString("N")[..8];
        var hasActiveChild = (menu.SubMenus ?? Enumerable.Empty<SecurityAgencyApp.Web.Models.Api.SubMenuItemDto>())
            .Where(s => s.IsActive)
            .Any(s => string.Equals(GetControllerName(s.Route ?? s.Name), controller, StringComparison.OrdinalIgnoreCase));
        <div class="menu-group">
            <a href="#" class="menu-item menu-parent @(hasActiveChild ? "active" : "")" data-bs-toggle="collapse" data-bs-target="#@menuId" aria-expanded="@(hasActiveChild ? "true" : "false")">
                @if (!string.IsNullOrEmpty(menu.Icon))
                {
                    <i class="@menu.Icon"></i>
                }
                <span>@(menu.DisplayName ?? menu.Name)</span>
                <i class="fas fa-chevron-down menu-chevron"></i>
            </a>
            <div class="collapse submenu-list @(hasActiveChild ? "show" : "")" id="@menuId">
                @foreach (var sub in (menu.SubMenus ?? Enumerable.Empty<SecurityAgencyApp.Web.Models.Api.SubMenuItemDto>()).Where(s => s.IsActive).OrderBy(s => s.DisplayOrder))
                {
                    var subRoute = sub.Route ?? sub.Name;
                    var subController = GetControllerName(subRoute);
                    var subActive = string.Equals(subController, controller, StringComparison.OrdinalIgnoreCase);
                    var subUrl = ResolveUrl(subRoute);
                    <a href="@subUrl" class="menu-item submenu-item @(subActive ? "active" : "")">
                        @if (!string.IsNullOrEmpty(sub.Icon))
                        {
                            <i class="@sub.Icon"></i>
                        }
                        <span>@(sub.DisplayName ?? sub.Name)</span>
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        var route = menu.Route ?? menu.Name;
        var menuController = GetControllerName(route);
        var isActive = string.Equals(menuController, controller, StringComparison.OrdinalIgnoreCase);
        var url = ResolveUrl(route);
        <a href="@url" class="menu-item @(isActive ? "active" : "")">
            @if (!string.IsNullOrEmpty(menu.Icon))
            {
                <i class="@menu.Icon"></i>
            }
            <span>@(menu.DisplayName ?? menu.Name)</span>
        </a>
    }
}
