<!DOCTYPE html>
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnv
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <meta name="theme-color" content="#1e293b" />
    <title>@ViewData["Title"] - Security Agency Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* Enterprise dashboard layout: fixed sidebar + main content. Main content width is constrained so sidebar + content never exceed viewport. */
        .sidebar {
            position: fixed;
            top: 0; left: 0;
            height: 100vh;
            width: var(--sidebar-width);
            max-width: 85vw;
            background: var(--bg-sidebar);
            color: var(--text-sidebar);
            z-index: 1050;
            transform: translateX(-100%);
            transition: width 0.25s var(--ease-out), transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
            overflow-x: hidden;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--border-sidebar);
        }
        .sidebar.show { transform: translateX(0); box-shadow: var(--shadow-lg); }
        @@media (min-width: 992px) {
            .sidebar { transform: translateX(0); box-shadow: none; }
            .sidebar.collapsed { width: var(--sidebar-collapsed-width); }
            .sidebar.collapsed .sidebar-brand span,
            .sidebar.collapsed .menu-item span,
            .sidebar.collapsed .menu-chevron,
            .sidebar.collapsed .menu-parent .menu-chevron,
            .sidebar.collapsed .submenu-list { display: none !important; }
            .sidebar.collapsed .menu-item { justify-content: center; padding-left: 0; padding-right: 0; border-radius: var(--radius-md); margin: 0 var(--space-2); }
            .sidebar.collapsed .menu-item i { margin-right: 0; }
            .sidebar.collapsed .menu-parent { justify-content: center; margin: 0 var(--space-2); border-radius: var(--radius-md); }
            .sidebar.collapsed .submenu-item { padding-left: 0 !important; justify-content: center; }
            .sidebar.collapsed .menu-group .menu-parent[aria-expanded="true"] + .submenu-list { display: none; }
        }
        .sidebar-header { padding: var(--space-5) var(--space-6); border-bottom: 1px solid var(--border-sidebar); flex-shrink: 0; }
        .sidebar-brand {
            display: flex; align-items: center; gap: var(--space-3);
            color: #fff; text-decoration: none; font-size: var(--text-lg); font-weight: var(--font-semibold); letter-spacing: -0.025em;
        }
        .sidebar-brand i { font-size: 1.35rem; color: var(--primary); flex-shrink: 0; }
        .sidebar-brand span { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .sidebar-menu { padding: var(--space-4) var(--space-3); flex: 1; }
        .menu-item {
            display: flex; align-items: center; padding: 10px 14px; min-height: 40px;
            color: var(--text-sidebar-muted); text-decoration: none;
            transition: background var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out);
            border-radius: var(--radius-md); margin-bottom: 2px;
        }
        .menu-item:hover { background: var(--bg-sidebar-hover); color: var(--text-sidebar); }
        .menu-item.active { background: var(--bg-sidebar-active); color: var(--primary); font-weight: var(--font-medium); }
        .menu-item i { width: 20px; margin-right: var(--space-3); flex-shrink: 0; text-align: center; opacity: 0.9; }
        .menu-group { margin-bottom: var(--space-1); }
        .menu-parent { display: flex; align-items: center; justify-content: space-between; }
        .menu-chevron { font-size: 0.65rem; transition: transform var(--duration-normal) var(--ease-out); margin-left: auto; opacity: 0.7; }
        .menu-parent[aria-expanded="true"] .menu-chevron { transform: rotate(180deg); }
        .submenu-list { background: transparent; }
        .submenu-item { padding-left: 44px !important; font-size: var(--text-sm); }
        .menu-item.active { box-shadow: inset 3px 0 0 var(--primary); }
        .sidebar-overlay {
            display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.45); z-index: 1040; opacity: 0; transition: opacity 0.25s var(--ease-out);
            backdrop-filter: blur(4px);
        }
        .sidebar-overlay.show { display: block; opacity: 1; }
        /* Main content: fills remaining space; constrained so sidebar + content never overflow viewport */
        .main-content {
            margin-left: 0;
            min-height: 100vh;
            flex: 1 1 0%;
            min-width: 0;
            width: 100%;
            display: flex;
            flex-direction: column;
            transition: margin-left 0.25s var(--ease-out), width 0.25s var(--ease-out);
            overflow-x: hidden;
        }
        @@media (min-width: 992px) {
            .main-content {
                margin-left: var(--sidebar-width);
                width: calc(100% - var(--sidebar-width));
                max-width: calc(100% - var(--sidebar-width));
            }
            .sidebar.collapsed ~ .main-content {
                margin-left: var(--sidebar-collapsed-width);
                width: calc(100% - var(--sidebar-collapsed-width));
                max-width: calc(100% - var(--sidebar-collapsed-width));
            }
            .btn-sidebar-toggle { display: none !important; }
        }
        .content-wrapper {
            flex: 1 1 auto;
            min-width: 0;
            width: 100%;
            max-width: 100%;
            padding: var(--space-6);
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
        }
        .page-content {
            flex: 1 1 auto;
            min-width: 0;
            width: 100%;
            max-width: 100%;
            margin-top: var(--space-4);
        }
        @@media (min-width: 576px) { .content-wrapper { padding: var(--space-8); } }
        @@media (min-width: 992px) {
            .content-wrapper { padding: var(--space-8) var(--space-10); }
            .page-content { margin-top: var(--space-6); }
        }
        @@media (max-width: 374px) { .content-wrapper { padding: var(--space-4); } }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>
    <aside class="sidebar" id="sidebar" role="navigation" aria-label="Main menu">
        <div class="sidebar-header">
            <a href="@Url.Action("Index", "Home")" class="sidebar-brand">
                <i class="fas fa-shield-alt"></i>
                <span>Security Agency</span>
            </a>
        </div>
        <nav class="sidebar-menu">
            @await Component.InvokeAsync("SidebarMenu")
        </nav>
    </aside>

    <div class="main-content">
        @await Html.PartialAsync("_Topbar")
        <div class="content-wrapper">
            @await Html.PartialAsync("_Breadcrumb")
            <div class="page-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await Html.PartialAsync("_ConfirmModal")
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var html = document.documentElement;
            function setTheme(theme) {
                html.setAttribute('data-theme', theme || 'light');
                try { localStorage.setItem('appTheme', theme || 'light'); } catch (e) {}
            }
            try {
                var saved = localStorage.getItem('appTheme');
                if (saved === 'dark' || saved === 'light') setTheme(saved);
            } catch (e) {}
            window.setAppTheme = setTheme;
        })();
    </script>
    <script>
        (function () {
            var sidebar = document.getElementById('sidebar');
            var overlay = document.getElementById('sidebarOverlay');
            var btnToggle = document.getElementById('btnSidebarToggle');
            var btnCollapse = document.getElementById('btnSidebarCollapse');
            function openMenu() {
                sidebar.classList.add('show');
                overlay.classList.add('show');
                overlay.setAttribute('aria-hidden', 'false');
                if (btnToggle) btnToggle.setAttribute('aria-label', 'Close menu');
            }
            function closeMenu() {
                sidebar.classList.remove('show');
                overlay.classList.remove('show');
                overlay.setAttribute('aria-hidden', 'true');
                if (btnToggle) btnToggle.setAttribute('aria-label', 'Open menu');
            }
            function toggleCollapse() {
                sidebar.classList.toggle('collapsed');
                var icon = btnCollapse ? btnCollapse.querySelector('i') : null;
                if (icon) {
                    icon.classList.toggle('fa-chevron-left');
                    icon.classList.toggle('fa-chevron-right');
                }
                var collapsed = sidebar.classList.contains('collapsed');
                try { localStorage.setItem('sidebarCollapsed', collapsed ? '1' : '0'); } catch (e) {}
            }
            if (btnToggle) btnToggle.addEventListener('click', function () { sidebar.classList.contains('show') ? closeMenu() : openMenu(); });
            if (overlay) overlay.addEventListener('click', closeMenu);
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeMenu(); });
            if (btnCollapse) btnCollapse.addEventListener('click', toggleCollapse);
            try {
                if (localStorage.getItem('sidebarCollapsed') === '1' && window.innerWidth >= 992) {
                    sidebar.classList.add('collapsed');
                    var icon = btnCollapse ? btnCollapse.querySelector('i') : null;
                    if (icon) { icon.classList.remove('fa-chevron-left'); icon.classList.add('fa-chevron-right'); }
                }
            } catch (e) {}
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
