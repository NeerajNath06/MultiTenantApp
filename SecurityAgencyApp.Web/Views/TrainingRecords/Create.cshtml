@model SecurityAgencyApp.Model.Api.CreateTrainingRecordRequest
@{
    ViewData["Title"] = "Add Training Record";
}

<div class="page-header">
    <h1 class="page-title">Add Training Record</h1>
    <p class="page-subtitle mb-0">Record guard training and certification</p>
</div>

<div class="card border-0 shadow-sm enterprise-form-card">
    <div class="card-body">
        <div id="trainingRecordFormPage"
             data-mode="create"
             data-submit-endpoint="TrainingRecords"
             data-redirect-url="@Url.Action("Index")">
        <form id="trainingRecordForm" class="form">
            <div id="trainingRecordFormErrors" class="alert alert-danger d-none"></div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="GuardId" class="form-label fw-semibold">Guard <span class="text-danger">*</span></label>
                    <select id="trainingRecordGuardId" asp-for="GuardId" class="form-select" required>
                        <option value="">Select Guard</option>
                    </select>
                    <span asp-validation-for="GuardId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="TrainingType" class="form-label fw-semibold">Training Type <span class="text-danger">*</span></label>
                    <input asp-for="TrainingType" class="form-control" placeholder="e.g., Basic, Fire Safety, First Aid" required />
                    <span asp-validation-for="TrainingType" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="TrainingName" class="form-label fw-semibold">Training Name <span class="text-danger">*</span></label>
                    <input asp-for="TrainingName" class="form-control" required />
                    <span asp-validation-for="TrainingName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="TrainingProvider" class="form-label fw-semibold">Training Provider</label>
                    <input asp-for="TrainingProvider" class="form-control" />
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="TrainingDate" class="form-label fw-semibold">Training Date <span class="text-danger">*</span></label>
                    <input asp-for="TrainingDate" type="date" class="form-control" required />
                    <span asp-validation-for="TrainingDate" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ExpiryDate" class="form-label fw-semibold">Expiry Date</label>
                    <input asp-for="ExpiryDate" type="date" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Status" class="form-label fw-semibold">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Scheduled">Scheduled</option>
                        <option value="Completed">Completed</option>
                        <option value="Failed">Failed</option>
                        <option value="Expired">Expired</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="CertificateNumber" class="form-label fw-semibold">Certificate Number</label>
                    <input asp-for="CertificateNumber" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Score" class="form-label fw-semibold">Score (%)</label>
                    <input asp-for="Score" type="number" step="0.01" min="0" max="100" class="form-control" />
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Remarks" class="form-label fw-semibold">Remarks</label>
                <textarea asp-for="Remarks" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-actions">
                <button id="trainingRecordFormSubmitButton" type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Add Training Record
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </div>
        </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/pages/training-records/form.js" asp-append-version="true"></script>
}
