@{
    ViewData["Title"] = "Training Record Details";
}

<div id="trainingRecordDetailsPage"
     data-training-record-id="@ViewBag.TrainingRecordId"
     data-load-endpoint="TrainingRecords/@ViewBag.TrainingRecordId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Training Record Details</h1>
            <p class="page-subtitle mb-0"><span data-field="trainingName">-</span> - <span data-field="guardName">-</span></p>
        </div>
        <div>
            <button id="trainingRecordDeleteButton" type="button" class="btn btn-outline-danger">
                <i class="fas fa-trash me-2"></i>Delete
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm enterprise-details-card">
    <div class="card-body">
        <h5 class="section-title"><i class="fas fa-graduation-cap"></i>Training Information</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Guard</label>
                <p class="mb-0"><strong data-field="guardName">-</strong> (<span data-field="guardCode">-</span>)</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Status</label>
                <p class="mb-0">
                    <span data-field="statusBadge" class="badge bg-secondary">-</span>
                </p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Training Type</label>
                <p class="mb-0" data-field="trainingType">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Training Name</label>
                <p class="mb-0" data-field="trainingName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Training Provider</label>
                <p class="mb-0" data-field="trainingProvider">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Training Date</label>
                <p class="mb-0" data-field="trainingDate">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Expiry Date</label>
                <p class="mb-0" data-field="expiryDate">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Certificate Number</label>
                <p class="mb-0" data-field="certificateNumber">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Score</label>
                <p class="mb-0" data-field="score">-</p>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold text-muted">Remarks</label>
                <p class="mb-0" data-field="remarks">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Created Date</label>
                <p class="mb-0" data-field="createdDate">-</p>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/training-records/details.js" asp-append-version="true"></script>
}
