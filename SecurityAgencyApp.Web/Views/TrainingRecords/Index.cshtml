@{
    ViewData["Title"] = "Training Records";
}

<div id="trainingRecordsIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-details-base="@Url.Action("Details", new { id = "__id__" })">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Training Records</h1>
            <p class="page-subtitle mb-0">Manage guard training and certifications</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-graduation-cap me-2"></i>Add Training Record
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Records</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Completed</div>
                <div class="stat-value" data-stat="completed">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Expired</div>
                <div class="stat-value" data-stat="expired">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-graduation-cap me-2 text-primary"></i>Training Directory</h5>
        <span id="trainingRecordsRecordCount" class="text-muted small">0 total records</span>
    </div>
    <div class="card-body">
        <div id="trainingRecordsTableWrapper"></div>
        <div id="trainingRecordsPaginationContainer" class="d-none mt-4">
            <div id="trainingRecordsPaginationSummary" class="text-muted small mb-2"></div>
            <ul id="trainingRecordsPagination" class="pagination justify-content-center mb-0"></ul>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/training-records/index.js" asp-append-version="true"></script>
}
