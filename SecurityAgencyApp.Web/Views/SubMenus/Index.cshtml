@model SecurityAgencyApp.Model.Api.SubMenuListResponse
@{
    ViewData["Title"] = "SubMenus Management";
    var selectedMenuId = ViewBag.SelectedMenuId as Guid?;
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">SubMenus</h1>
            <p class="page-subtitle mb-0">Manage submenu items</p>
        </div>
        <div class="d-flex gap-2" id="subMenusActions">
            <select id="menuFilter" class="form-select" style="width: auto;">
                <option value="">All Menus</option>
            </select>
            <a href="@Url.Action("Create", new { menuId = selectedMenuId })" class="btn btn-primary @(selectedMenuId.HasValue ? "" : "d-none")" id="subMenusCreateButton">
                <i class="fas fa-plus me-2"></i>Add New SubMenu
            </a>
        </div>
    </div>
</div>

<div class="row g-3 mb-4" id="subMenusStats">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Submenus</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Items</div>
                <div class="stat-value" data-stat="active">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Linked Menus</div>
                <div class="stat-value" data-stat="menus">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden" id="subMenusIndexPage"
     data-index-url="@Url.Action("Index", "SubMenus")"
     data-selected-menu-id="@(selectedMenuId?.ToString() ?? string.Empty)"
     data-edit-base="@Url.Action("Edit", "SubMenus", new { id = "__id__" })"
     data-create-base="@Url.Action("Create", "SubMenus", new { menuId = "__id__" })">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-list-ul me-2 text-primary"></i>Submenu Directory</h5>
        <span class="text-muted small" id="subMenusRecordCount">0 visible records</span>
    </div>
    <div class="card-body">
        <div id="subMenusTableWrapper">
            <div class="text-center py-5">
                <i class="fas fa-list-ul fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">Loading submenus...</h5>
                <p class="text-muted">Fetching latest data from API.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/submenus/index.js" asp-append-version="true"></script>
}
