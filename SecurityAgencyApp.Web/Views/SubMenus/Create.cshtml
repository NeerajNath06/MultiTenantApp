@model SecurityAgencyApp.Model.Api.CreateSubMenuRequest
@{
    ViewData["Title"] = "Create SubMenu";
}

<div class="page-header">
    <h1 class="page-title">Create New SubMenu</h1>
    <p class="page-subtitle mb-0">Add a new submenu item</p>
</div>

<div class="card border-0 shadow-sm enterprise-form-card" id="subMenuFormPage" data-mode="create" data-submit-endpoint="SubMenus" data-redirect-url="@Url.Action("Index", "SubMenus", new { menuId = Model.MenuId })">
    <div class="card-body">
        <form class="form" id="subMenuForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert" id="subMenuFormErrors"></div>
            
            <input type="hidden" asp-for="MenuId" id="subMenuMenuId" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label fw-semibold">SubMenu Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter submenu name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DisplayName" class="form-label fw-semibold">Display Name</label>
                    <input asp-for="DisplayName" class="form-control" placeholder="Enter display name" />
                    <span asp-validation-for="DisplayName" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-6">
                    <label asp-for="Icon" class="form-label fw-semibold">Icon (Font Awesome class)</label>
                    <input asp-for="Icon" class="form-control" placeholder="fas fa-file" />
                    <small class="text-muted">Example: fas fa-file, fas fa-list</small>
                    <span asp-validation-for="Icon" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Route" class="form-label fw-semibold">Route</label>
                    <input asp-for="Route" class="form-control" placeholder="/users" />
                    <span asp-validation-for="Route" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-6">
                    <label asp-for="DisplayOrder" class="form-label fw-semibold">Display Order</label>
                    <input asp-for="DisplayOrder" type="number" class="form-control" value="0" />
                    <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <div class="form-check mt-4">
                        <input asp-for="IsActive" type="checkbox" class="form-check-input" checked />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary" id="subMenuFormSubmitButton">
                    <i class="fas fa-save me-2"></i>Create SubMenu
                </button>
                <a href="@Url.Action("Index", "Menus")" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/submenus/form.js" asp-append-version="true"></script>
}
