@model SecurityAgencyApp.Model.Api.CreateSitePostRequest
@{
    ViewData["Title"] = "Create Site Post";
    ViewData["Breadcrumbs"] = new[] { ("Site Posts", Url.Action("Index")), ("Create Site Post", (string?)null) };
}

<div class="page-header">
    <h1 class="page-title">Create Site Post</h1>
    <p class="page-subtitle mb-0">Add a dedicated post under a site for staffing and planning.</p>
</div>

<div class="card border-0 shadow-sm enterprise-form-card">
    <div class="card-body">
        <div id="sitePostFormPage"
             data-mode="create"
             data-submit-endpoint="SitePosts"
             data-redirect-url="@Url.Action("Index")">
        <form id="sitePostForm" class="form">
            <div id="sitePostFormErrors" class="alert alert-danger d-none" role="alert"></div>
            <partial name="_SitePostFormFields" model="Model" />
            <div class="form-actions">
                <button id="sitePostFormSubmitButton" type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Create Site Post
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </div>
        </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/pages/site-posts/form.js" asp-append-version="true"></script>
}
