@{
    ViewData["Title"] = "Site Post Details";
    ViewData["Breadcrumbs"] = new[] { ("Site Posts", Url.Action("Index")), ("Site Post Details", (string?)null) };
}

<div id="sitePostDetailsPage"
     data-site-post-id="@ViewBag.SitePostId"
     data-load-endpoint="SitePosts/@ViewBag.SitePostId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="page-title">Site Post Details</h1>
            <p class="page-subtitle mb-0"><span data-field="postName">-</span> - <span data-field="postCode">-</span></p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Edit", new { id = ViewBag.SitePostId })" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Site Posts
            </a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <div class="form-section">
                    <h5 class="section-title"><i class="fas fa-users-cog"></i>Post Overview</h5>
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Site</label>
                            <p class="mb-0" data-field="siteName">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Branch</label>
                            <p class="mb-0" data-field="branchName">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Post Code</label>
                            <p class="mb-0" data-field="postCode">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Post Name</label>
                            <p class="mb-0" data-field="postName">-</p>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold text-muted">Shift</label>
                            <p class="mb-0" data-field="shiftName">-</p>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold text-muted">Sanctioned Strength</label>
                            <p class="mb-0" data-field="sanctionedStrength">-</p>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold text-muted">Weekly Off Pattern</label>
                            <p class="mb-0" data-field="weeklyOffPattern">-</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-shield-alt"></i>Operational Flags</h5>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Gender Requirement</label>
                    <p class="mb-0" data-field="genderRequirement">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Skill Requirement</label>
                    <p class="mb-0" data-field="skillRequirement">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Requires Weapon</label>
                    <p class="mb-0" data-field="requiresWeapon">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Reliever Required</label>
                    <p class="mb-0" data-field="relieverRequired">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Status</label>
                    <p class="mb-0">
                        <span data-field="statusBadge" class="badge bg-secondary">-</span>
                    </p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Created</label>
                    <p class="mb-0" data-field="createdDate">-</p>
                </div>
                <div class="mb-0">
                    <label class="form-label fw-semibold text-muted">Last Modified</label>
                    <p class="mb-0" data-field="modifiedDate">-</p>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/site-posts/details.js" asp-append-version="true"></script>
}
