@model SecurityAgencyApp.Web.Models.Api.SitePostListResponse
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Site Posts";
    ViewData["Breadcrumbs"] = new[] { ("Site Posts", (string?)null) };
    var search = ViewBag.Search as string;
    var sites = ViewBag.Sites as SelectList ?? new SelectList(Enumerable.Empty<SelectListItem>());
    var branches = ViewBag.Branches as SelectList ?? new SelectList(Enumerable.Empty<SelectListItem>());
    var totalPosts = Model?.Items?.Count ?? 0;
    var activePosts = Model?.Items?.Count(p => p.IsActive) ?? 0;
    var sanctionedStrength = Model?.Items?.Sum(p => p.SanctionedStrength) ?? 0;
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="page-title">Site Posts</h1>
            <p class="page-subtitle mb-0">Manage site-wise posts, sanctioned strength, and staffing requirements.</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add Site Post
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Visible Posts</div>
                <div class="stat-value">@totalPosts</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Posts</div>
                <div class="stat-value">@activePosts</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Sanctioned Strength</div>
                <div class="stat-value">@sanctionedStrength</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-users-cog me-2 text-primary"></i>Site Post Directory</h5>
        <span class="text-muted small">@totalPosts visible records</span>
    </div>
    <form method="get" action="@Url.Action("Index")" class="table-toolbar flex-wrap gap-2">
        <div class="search-wrap">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" name="search" class="form-control border-start-0" placeholder="Search by code, post, shift..." value="@search" />
            </div>
        </div>
        <select name="siteId" class="form-select form-select-sm" style="max-width: 220px;" asp-items="sites">
            <option value="">All sites</option>
        </select>
        <select name="branchId" class="form-select form-select-sm" style="max-width: 220px;" asp-items="branches">
            <option value="">All branches</option>
        </select>
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="fas fa-filter me-1"></i>Apply
        </button>
        @if (!string.IsNullOrWhiteSpace(search) || Model.SiteId.HasValue || Model.BranchId.HasValue)
        {
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Clear</a>
        }
    </form>

    <div class="card-body p-0">
        @if (Model.Items.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Post</th>
                            <th>Site / Branch</th>
                            <th>Shift</th>
                            <th>Strength</th>
                            <th>Requirements</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var post in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@post.PostName</div>
                                    <div class="small text-muted">@post.PostCode</div>
                                </td>
                                <td>
                                    <div>@post.SiteName</div>
                                    <div class="small text-muted">@(post.BranchName ?? "No branch")</div>
                                </td>
                                <td>@(post.ShiftName ?? "-")</td>
                                <td>
                                    <span class="badge bg-info">@post.SanctionedStrength</span>
                                </td>
                                <td>
                                    <div class="small">@(post.GenderRequirement ?? "No gender rule")</div>
                                    <div class="small text-muted">@(post.SkillRequirement ?? "No skill rule")</div>
                                    <div class="small text-muted">
                                        Weapon: @(post.RequiresWeapon ? "Yes" : "No") | Reliever: @(post.RelieverRequired ? "Yes" : "No")
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-@(post.IsActive ? "success" : "secondary")">
                                        @(post.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="action-btns">
                                        <a href="@Url.Action("Details", new { id = post.Id })" class="btn btn-sm btn-outline-primary" title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = post.Id })" class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="d-inline" data-confirm-message="Are you sure you want to delete this site post?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@post.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-users-cog fa-3x text-muted mb-3 opacity-50"></i>
                <h5 class="text-muted">No site posts found</h5>
                <p class="text-muted small mb-0">Create site posts to manage sanctioned positions and staffing rules.</p>
                <a href="@Url.Action("Create")" class="btn btn-primary mt-3">
                    <i class="fas fa-plus me-2"></i>Add Site Post
                </a>
            </div>
        }
    </div>
</div>
