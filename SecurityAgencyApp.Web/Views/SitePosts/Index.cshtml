@{
    ViewData["Title"] = "Site Posts";
    ViewData["Breadcrumbs"] = new[] { ("Site Posts", (string?)null) };
    var search = ViewBag.Search as string;
}

<div id="sitePostsIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-details-base="@Url.Action("Details", new { id = "__id__" })"
     data-edit-base="@Url.Action("Edit", new { id = "__id__" })">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="page-title">Site Posts</h1>
            <p class="page-subtitle mb-0">Manage site-wise posts, sanctioned strength, and staffing requirements.</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add Site Post
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Visible Posts</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Posts</div>
                <div class="stat-value" data-stat="active">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Sanctioned Strength</div>
                <div class="stat-value" data-stat="strength">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-users-cog me-2 text-primary"></i>Site Post Directory</h5>
        <span id="sitePostsRecordCount" class="text-muted small">0 visible records</span>
    </div>
    <form id="sitePostsFilterForm" method="get" action="@Url.Action("Index")" class="table-toolbar flex-wrap gap-2">
        <div class="search-wrap">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" name="search" class="form-control border-start-0" placeholder="Search by code, post, shift..." value="@search" />
            </div>
        </div>
        <select id="sitePostsFilterSiteId" name="siteId" class="form-select form-select-sm" style="max-width: 220px;">
            <option value="">All sites</option>
        </select>
        <select id="sitePostsFilterBranchId" name="branchId" class="form-select form-select-sm" style="max-width: 220px;">
            <option value="">All branches</option>
        </select>
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="fas fa-filter me-1"></i>Apply
        </button>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Clear</a>
    </form>

    <div class="card-body p-0">
        <div id="sitePostsTableWrapper"></div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/site-posts/index.js" asp-append-version="true"></script>
}
