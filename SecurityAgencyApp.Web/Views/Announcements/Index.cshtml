@{
    ViewData["Title"] = "Announcements";
}

<div id="announcementsIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-edit-base="@Url.Action("Edit", new { id = "__id__" })">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Announcements</h1>
            <p class="page-subtitle mb-0">Manage announcements</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>New Announcement
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Announcements</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Pinned</div>
                <div class="stat-value" data-stat="pinned">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active</div>
                <div class="stat-value" data-stat="active">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search & Filters</h5>
    </div>
    <div class="card-body">
        <form id="announcementsFilterForm" method="get" class="row g-3">
            <input type="hidden" name="pageNumber" value="1" />
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input type="text" name="search" class="form-control" placeholder="Title, content..." value="@ViewContext.HttpContext.Request.Query["search"]" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Category</label>
                <input type="text" name="category" class="form-control" value="@ViewContext.HttpContext.Request.Query["category"]" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Pinned</label>
                <select name="isPinned" class="form-select">
                    <option value="">All</option>
                    <option value="true" selected="@(ViewContext.HttpContext.Request.Query["isPinned"] == "true")">Pinned</option>
                    <option value="false" selected="@(ViewContext.HttpContext.Request.Query["isPinned"] == "false")">Not Pinned</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">&nbsp;</label>
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search me-2"></i>Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-bullhorn me-2 text-primary"></i>Announcement Directory</h5>
        <span id="announcementsRecordCount" class="text-muted small">0 total records</span>
    </div>
    <div class="card-body">
        <div id="announcementsTableWrapper"></div>
        <div id="announcementsPaginationContainer" class="d-none mt-3">
            <div id="announcementsPaginationSummary" class="text-muted small mb-2"></div>
            <ul id="announcementsPagination" class="pagination justify-content-center mb-0"></ul>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/announcements/index.js" asp-append-version="true"></script>
}
