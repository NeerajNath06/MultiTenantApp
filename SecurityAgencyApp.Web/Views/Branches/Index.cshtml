@model SecurityAgencyApp.Web.Models.Api.BranchListResponse
@{
    ViewData["Title"] = "Branches";
    ViewData["Breadcrumbs"] = new[] { ("Branches", (string?)null) };
    var search = ViewBag.Search as string;
    var totalBranches = Model?.Items?.Count() ?? 0;
    var activeBranches = Model?.Items?.Count(b => b.IsActive) ?? 0;
    var headOfficeCount = Model?.Items?.Count(b => b.IsHeadOffice) ?? 0;
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="page-title">Branches</h1>
            <p class="page-subtitle mb-0">Manage operational branches used by sites, numbering, and compliance.</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add Branch
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Branches</div>
                <div class="stat-value">@totalBranches</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Branches</div>
                <div class="stat-value">@activeBranches</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Head Offices</div>
                <div class="stat-value">@headOfficeCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search & Filters</h5>
    </div>
    <form method="get" action="@Url.Action("Index")" class="table-toolbar">
        <div class="search-wrap">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" name="search" class="form-control border-start-0" placeholder="Search by branch code, name, city..." value="@search" />
            </div>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="fas fa-filter me-1"></i>Apply
        </button>
        @if (!string.IsNullOrWhiteSpace(search))
        {
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Clear</a>
        }
    </form>

    <div class="card-body p-0">
        @if (Model?.Items != null && Model.Items.Any())
        {
            <div class="px-4 py-3 border-bottom bg-body-tertiary d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h5 class="mb-0"><i class="fas fa-code-branch me-2 text-primary"></i>Branch Directory</h5>
                <span class="text-muted small">@totalBranches total records</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Branch</th>
                            <th>Location</th>
                            <th>Contact</th>
                            <th>Compliance</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var branch in Model.Items.OrderBy(b => b.BranchName))
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@branch.BranchName</div>
                                    <div class="small text-muted">@branch.BranchCode</div>
                                </td>
                                <td>
                                    <div>@branch.City, @branch.State</div>
                                    <div class="small text-muted">@branch.PinCode</div>
                                </td>
                                <td>
                                    <div>@(branch.ContactPerson ?? "-")</div>
                                    <div class="small text-muted">@(branch.ContactPhone ?? "-")</div>
                                </td>
                                <td>
                                    <div class="small">GST: @(branch.GstNumber ?? "-")</div>
                                    <div class="small text-muted">License: @(branch.LabourLicenseNumber ?? "-")</div>
                                </td>
                                <td>
                                    @if (branch.IsHeadOffice)
                                    {
                                        <span class="badge bg-info me-1">Head Office</span>
                                    }
                                    <span class="badge bg-@(branch.IsActive ? "success" : "secondary")">
                                        @(branch.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="action-btns">
                                        <a href="@Url.Action("Details", new { id = branch.Id })" class="btn btn-sm btn-outline-primary" title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = branch.Id })" class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="d-inline" data-confirm-message="Are you sure you want to delete this branch?">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@branch.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-code-branch fa-3x text-muted mb-3 opacity-50"></i>
                <h5 class="text-muted">No branches found</h5>
                <p class="text-muted small mb-0">Create your first branch to assign it to sites.</p>
                <a href="@Url.Action("Create")" class="btn btn-primary mt-3">
                    <i class="fas fa-plus me-2"></i>Add Branch
                </a>
            </div>
        }
    </div>
</div>
