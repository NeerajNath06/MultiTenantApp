@model SecurityAgencyApp.Web.Models.Api.UpdateShiftRequest
@{
    ViewData["Title"] = "Edit Shift";
}

<div class="page-header">
    <h1 class="page-title">Edit Shift</h1>
    <p class="page-subtitle mb-0">Update shift details</p>
</div>

<div class="card border-0 shadow-sm enterprise-form-card">
    <div class="card-body">
        <form asp-action="Edit" method="post" class="form">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <div class="form-section">
                <h5 class="section-title"><i class="fas fa-clock"></i>Shift Details</h5>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="ShiftName" class="form-label fw-semibold">Shift Name <span class="text-danger">*</span></label>
                        <input asp-for="ShiftName" class="form-control" placeholder="e.g., Morning Shift" />
                        <span asp-validation-for="ShiftName" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-3">
                        <label asp-for="StartTime" class="form-label fw-semibold">Start Time <span class="text-danger">*</span></label>
                        <input asp-for="StartTime" type="time" class="form-control" />
                        <span asp-validation-for="StartTime" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-3">
                        <label asp-for="EndTime" class="form-label fw-semibold">End Time <span class="text-danger">*</span></label>
                        <input asp-for="EndTime" type="time" class="form-control" />
                        <span asp-validation-for="EndTime" class="text-danger small"></span>
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-12 col-md-6">
                        <label asp-for="BreakDuration" class="form-label fw-semibold">Break Duration (minutes)</label>
                        <input asp-for="BreakDuration" type="number" class="form-control" min="0" />
                        <span asp-validation-for="BreakDuration" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="IsActive" class="form-label fw-semibold">Status</label>
                        <div class="form-check form-switch mt-2">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Update Shift</button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary"><i class="fas fa-times me-2"></i>Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
