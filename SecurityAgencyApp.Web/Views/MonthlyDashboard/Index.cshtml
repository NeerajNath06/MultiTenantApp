@model SecurityAgencyApp.Web.Models.Api.MonthlySiteSummaryResponseDto
@{
    ViewData["Title"] = "Monthly Dashboard";
    var curYear = DateTime.UtcNow.Year;
    var curMonth = DateTime.UtcNow.Month;
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="page-title">Monthly Dashboard</h1>
            <p class="page-subtitle mb-0">Present days + latest Bill total + latest Wage total (Present-only policy)</p>
        </div>
        <a class="btn btn-outline-secondary" href="@Url.Action("Index", "Sites")">
            <i class="fas fa-building me-2"></i>Sites
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold">Year</label>
                <select class="form-select" name="year">
                    @for (var y = curYear; y >= curYear - 5; y--)
                    {
                        <option value="@y" selected="@(Model.Year == y)">@y</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label fw-semibold">Month</label>
                <select class="form-select" name="month">
                    @for (var m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(Model.Month == m)">@((new DateTime(2000, m, 1)).ToString("MMMM"))</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-sync-alt me-2"></i>Load
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Site</th>
                        <th>Client</th>
                        <th class="text-end">Present (count)</th>
                        <th class="text-end">Latest Bill Total</th>
                        <th class="text-end">Latest Wage Total</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var i in Model.Items)
                        {
                            <tr>
                                <td class="fw-semibold">@i.SiteName</td>
                                <td>@i.ClientName</td>
                                <td class="text-end">@i.PresentDaysTotal</td>
                                <td class="text-end">@((i.LatestBillTotal ?? 0m).ToString("0.00"))</td>
                                <td class="text-end">@((i.LatestWageTotal ?? 0m).ToString("0.00"))</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" title="Rate" href="@Url.Action("Index", "SiteRates", new { siteId = i.SiteId })">
                                        <i class="fas fa-rupee-sign"></i>
                                    </a>
                                    <a class="btn btn-sm btn-outline-info" title="Generate Report" href="@Url.Action("Edit", "Sites", new { id = i.SiteId })">
                                        <i class="fas fa-file-alt"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-muted">No data for selected month.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

