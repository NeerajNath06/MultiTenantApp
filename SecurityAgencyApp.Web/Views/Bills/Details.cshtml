@{
    ViewData["Title"] = "Bill Details";
    var billId = ViewBag.BillId;
}

<div id="billDetailsPage"
     data-bill-id="@billId"
     data-load-endpoint="Bills/@billId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Bill Details</h1>
            <p class="page-subtitle mb-0">View bill information</p>
        </div>
        <div>
            <a href="@Url.Action("Edit", new { id = billId })" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <button type="button" id="billDeleteButton" class="btn btn-outline-danger">
                <i class="fas fa-trash me-2"></i>Delete
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-file-invoice"></i>Bill Information</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Bill Number</label>
                        <p class="mb-0"><strong data-field="billNumber">-</strong></p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Bill Date</label>
                        <p class="mb-0" data-field="billDate">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Client Name</label>
                        <p class="mb-0" data-field="clientName">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Site</label>
                        <p class="mb-0" data-field="siteName">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Status</label>
                        <p class="mb-0">
                            <span class="badge bg-secondary" data-field="statusBadge">-</span>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Due Date</label>
                        <p class="mb-0" data-field="dueDate">-</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Description</label>
                        <p class="mb-0" data-field="description">-</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm enterprise-details-card mt-4">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-list"></i>Bill Items</h5>
                <div id="billItemsWrapper"></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-calculator"></i>Summary</h5>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Sub Total</label>
                    <p class="mb-0"><strong data-field="subTotal">-</strong></p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Discount</label>
                    <p class="mb-0" data-field="discountAmount">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Tax</label>
                    <p class="mb-0" data-field="taxAmount">-</p>
                </div>
                <div class="mb-3 border-top pt-3">
                    <label class="form-label fw-semibold text-muted">Total Amount</label>
                    <p class="mb-0"><strong class="text-success fs-5" data-field="totalAmount">-</strong></p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Payment Terms</label>
                    <p class="mb-0" data-field="paymentTerms">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Notes</label>
                    <p class="mb-0" data-field="notes">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Created Date</label>
                    <p class="mb-0" data-field="createdDate">-</p>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/bills/details.js" asp-append-version="true"></script>
}
