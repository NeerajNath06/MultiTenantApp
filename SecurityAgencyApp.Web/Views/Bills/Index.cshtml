@{
    ViewData["Title"] = "Bills Management";
}

<div id="billsIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-details-base="@Url.Action("Details", new { id = "__id__" })"
     data-edit-base="@Url.Action("Edit", new { id = "__id__" })">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Bills</h1>
            <p class="page-subtitle mb-0">Manage client bills</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-file-invoice me-2"></i>Create New Bill
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Bills</div>
                    <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Paid Bills</div>
                    <div class="stat-value" data-stat="paid">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Overdue Bills</div>
                    <div class="stat-value" data-stat="overdue">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search &amp; Filters</h5>
    </div>
    <div class="card-body">
        <form id="billsFilterForm" class="row g-3 form">
            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="10" />
            <div class="col-md-8">
                <input type="text" id="billsSearch" name="search" class="form-control" placeholder="Search bill number, client..." />
            </div>
            <div class="col-md-3">
                <select id="billsStatus" name="status" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="Draft">Draft</option>
                    <option value="Sent">Sent</option>
                    <option value="Paid">Paid</option>
                    <option value="Overdue">Overdue</option>
                    <option value="Cancelled">Cancelled</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search"></i></button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-file-invoice me-2 text-primary"></i>Billing Directory</h5>
        <span id="billsRecordCount" class="text-muted small">0 total records</span>
    </div>
    <div class="card-body">
        <div id="billsTableWrapper"></div>
        <div id="billsPaginationContainer" class="mt-4 d-none">
            <div id="billsPaginationSummary" class="text-muted text-center small mb-2"></div>
            <ul id="billsPagination" class="pagination justify-content-center"></ul>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/bills/index.js" asp-append-version="true"></script>
}
