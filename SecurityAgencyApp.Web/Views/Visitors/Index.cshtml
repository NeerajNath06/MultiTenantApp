@{
    ViewData["Title"] = "Visitors";
}

<div id="visitorsIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-details-base="@Url.Action("Details", new { id = "__id__" })"
     data-edit-base="@Url.Action("Edit", new { id = "__id__" })">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Visitor Log</h1>
            <p class="page-subtitle mb-0">Register and track visitors</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-user-plus me-2"></i>Register Visitor
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Visitors</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Inside Premises</div>
                <div class="stat-value" data-stat="inside">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Company Visitors</div>
                <div class="stat-value" data-stat="company">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search & Filters</h5>
    </div>
    <div class="card-body">
        <form id="visitorsFilterForm" method="get" class="row g-3">
            <input type="hidden" name="pageNumber" value="1" />
            <div class="col-md-2">
                <label class="form-label">Site</label>
                <select id="visitorsFilterSiteId" name="siteId" class="form-select">
                    <option value="">All Sites</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Guard</label>
                <select id="visitorsFilterGuardId" name="guardId" class="form-select">
                    <option value="">All Guards</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">From Date</label>
                <input type="date" name="dateFrom" class="form-control" value="@ViewContext.HttpContext.Request.Query["dateFrom"]" />
            </div>
            <div class="col-md-2">
                <label class="form-label">To Date</label>
                <input type="date" name="dateTo" class="form-control" value="@ViewContext.HttpContext.Request.Query["dateTo"]" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Inside Only</label>
                <select name="insideOnly" class="form-select">
                    <option value="">All</option>
                    <option value="true" selected="@(ViewContext.HttpContext.Request.Query["insideOnly"] == "true")">Inside Only</option>
                    <option value="false" selected="@(ViewContext.HttpContext.Request.Query["insideOnly"] == "false")">Exited</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Search</label>
                <input type="text" name="search" class="form-control" placeholder="Name, company..." value="@ViewContext.HttpContext.Request.Query["search"]" />
            </div>
            <div class="col-12">
                <button type="submit" class="btn btn-primary"><i class="fas fa-filter me-2"></i>Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-user-friends me-2 text-primary"></i>Visitor Directory</h5>
        <span id="visitorsRecordCount" class="text-muted small">0 total records</span>
    </div>
    <div class="card-body">
        <div id="visitorsTableWrapper"></div>
        <div id="visitorsPaginationContainer" class="d-none mt-3">
            <div id="visitorsPaginationSummary" class="text-muted small mb-2"></div>
            <ul id="visitorsPagination" class="pagination justify-content-center mb-0"></ul>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/visitors/index.js" asp-append-version="true"></script>
}
