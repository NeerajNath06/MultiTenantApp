@model SecurityAgencyApp.Web.Models.Api.VisitorDetailDto
@{
    ViewData["Title"] = "Visitor Details";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Visitor Details</h1>
            <p class="page-subtitle mb-0">@Model.VisitorName</p>
        </div>
        <div>
            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <form asp-action="Delete" method="post" class="d-inline" data-confirm-message="Are you sure you want to delete this visitor record?">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-outline-danger">
                    <i class="fas fa-trash me-2"></i>Delete
                </button>
            </form>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5 class="card-title mb-4">Visitor Information</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Visitor Name</label>
                <p class="mb-0"><strong>@Model.VisitorName</strong></p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Type</label>
                <p class="mb-0">@Model.VisitorType</p>
            </div>
            @if (!string.IsNullOrEmpty(Model.CompanyName))
            {
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Company</label>
                    <p class="mb-0">@Model.CompanyName</p>
                </div>
            }
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Phone</label>
                <p class="mb-0">@Model.PhoneNumber</p>
            </div>
            @if (!string.IsNullOrEmpty(Model.Email))
            {
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Email</label>
                    <p class="mb-0">@Model.Email</p>
                </div>
            }
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Purpose</label>
                <p class="mb-0">@Model.Purpose</p>
            </div>
            @if (!string.IsNullOrEmpty(Model.HostName))
            {
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Host Name</label>
                    <p class="mb-0">@Model.HostName</p>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.HostDepartment))
            {
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Host Department</label>
                    <p class="mb-0">@Model.HostDepartment</p>
                </div>
            }
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Site</label>
                <p class="mb-0">@(Model.SiteName ?? "-")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Guard</label>
                <p class="mb-0">@(Model.GuardName ?? "-")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Entry Time</label>
                <p class="mb-0">@Model.EntryTime.ToString("dd MMM yyyy HH:mm")</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Exit Time</label>
                <p class="mb-0">@(Model.ExitTime.HasValue ? Model.ExitTime.Value.ToString("dd MMM yyyy HH:mm") : "Inside")</p>
            </div>
            @if (!string.IsNullOrEmpty(Model.BadgeNumber))
            {
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Badge Number</label>
                    <p class="mb-0">@Model.BadgeNumber</p>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.IdProofType))
            {
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">ID Proof</label>
                    <p class="mb-0">@Model.IdProofType @(string.IsNullOrEmpty(Model.IdProofNumber) ? "" : "- " + Model.IdProofNumber)</p>
                </div>
            }
        </div>
    </div>
</div>
