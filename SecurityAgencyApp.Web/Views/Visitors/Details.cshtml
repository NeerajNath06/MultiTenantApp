@{
    ViewData["Title"] = "Visitor Details";
}

<div id="visitorDetailsPage"
     data-visitor-id="@ViewBag.VisitorId"
     data-load-endpoint="Visitors/@ViewBag.VisitorId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Visitor Details</h1>
            <p class="page-subtitle mb-0" data-field="visitorName">-</p>
        </div>
        <div>
            <a href="@Url.Action("Edit", new { id = ViewBag.VisitorId })" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <button id="visitorDeleteButton" type="button" class="btn btn-outline-danger">
                <i class="fas fa-trash me-2"></i>Delete
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm enterprise-details-card">
    <div class="card-body">
        <h5 class="section-title"><i class="fas fa-user-friends"></i>Visitor Information</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Visitor Name</label>
                <p class="mb-0"><strong data-field="visitorName">-</strong></p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Type</label>
                <p class="mb-0" data-field="visitorType">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Company</label>
                <p class="mb-0" data-field="companyName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Phone</label>
                <p class="mb-0" data-field="phoneNumber">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Email</label>
                <p class="mb-0" data-field="email">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Purpose</label>
                <p class="mb-0" data-field="purpose">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Host Name</label>
                <p class="mb-0" data-field="hostName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Host Department</label>
                <p class="mb-0" data-field="hostDepartment">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Site</label>
                <p class="mb-0" data-field="siteName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Guard</label>
                <p class="mb-0" data-field="guardName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Entry Time</label>
                <p class="mb-0" data-field="entryTime">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Exit Time</label>
                <p class="mb-0" data-field="exitTime">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Badge Number</label>
                <p class="mb-0" data-field="badgeNumber">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">ID Proof</label>
                <p class="mb-0" data-field="idProof">-</p>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/visitors/details.js" asp-append-version="true"></script>
}
