@model SecurityAgencyApp.Web.Models.Api.NotificationListResponse
@{
    ViewData["Title"] = "My Notifications";
    var totalNotifications = Model?.Items?.Count ?? 0;
    var unreadNotifications = Model?.UnreadCount ?? 0;
    var readNotifications = Math.Max(totalNotifications - unreadNotifications, 0);
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">My Notifications</h1>
            <p class="page-subtitle mb-0">@(Model?.UnreadCount ?? 0) unread</p>
        </div>
        <div>
            <a href="@Url.Action("Send")" class="btn btn-primary me-2">
                <i class="fas fa-paper-plane me-2"></i>Send Notification
            </a>
            @if (Model?.UnreadCount > 0)
            {
                <form asp-action="MarkAllAsRead" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary">Mark all read</button>
                </form>
            }
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Visible Notifications</div>
                <div class="stat-value">@totalNotifications</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Unread</div>
                <div class="stat-value">@unreadNotifications</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Read</div>
                <div class="stat-value">@readNotifications</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-bell me-2 text-primary"></i>Notification Feed</h5>
        <span class="text-muted small">@unreadNotifications unread right now</span>
    </div>
    <div class="card-body">
        @if (Model?.Items != null && Model.Items.Any())
        {
            <div class="list-group list-group-flush">
                @foreach (var n in Model.Items)
                {
                    <div class="list-group-item border-0 px-0 py-3 @(n.IsRead ? "" : "bg-light")">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <h6 class="mb-1 @(n.IsRead ? "text-muted fw-normal" : "fw-semibold")">
                                    @n.Title
                                    @if (!n.IsRead) { <span class="badge bg-primary ms-2">New</span> }
                                </h6>
                                <p class="mb-0 text-muted small">@n.Body</p>
                                <small class="text-muted">@n.CreatedAt.ToString("dd MMM yyyy HH:mm") · @n.Type</small>
                            </div>
                            @if (!n.IsRead)
                            {
                                <form asp-action="MarkAsRead" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@n.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Mark read</button>
                                </form>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-bell-slash fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No notifications</h5>
                <a href="@Url.Action("Send")" class="btn btn-primary mt-3"><i class="fas fa-paper-plane me-2"></i>Send Notification</a>
            </div>
        }
    </div>
</div>
