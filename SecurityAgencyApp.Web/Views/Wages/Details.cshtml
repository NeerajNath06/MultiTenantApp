@{
    ViewData["Title"] = "Wage Sheet Details";
    var wageId = ViewBag.WageId;
}

<div id="wageDetailsPage"
     data-wage-id="@wageId"
     data-load-endpoint="Wages/@wageId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Wage Sheet Details</h1>
            <p class="page-subtitle mb-0" data-field="wageSheetNumber">-</p>
        </div>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-money-bill-wave"></i>Wage Information</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Wage Sheet Number</label>
                        <p class="mb-0"><strong data-field="wageSheetNumber">-</strong></p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Period</label>
                        <p class="mb-0" data-field="wagePeriod">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Payment Date</label>
                        <p class="mb-0" data-field="paymentDate">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Status</label>
                        <p class="mb-0">
                            <span class="badge bg-secondary" data-field="statusBadge">-</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm enterprise-details-card mt-4">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-list-ul"></i>Wage Details</h5>
                <div id="wageDetailsTableWrapper"></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-calculator"></i>Summary</h5>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Total Wages</label>
                    <p class="mb-0" data-field="totalWages">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Total Allowances</label>
                    <p class="mb-0" data-field="totalAllowances">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Total Deductions</label>
                    <p class="mb-0" data-field="totalDeductions">-</p>
                </div>
                <div class="mb-3 border-top pt-3">
                    <label class="form-label fw-semibold text-muted">Net Amount</label>
                    <p class="mb-0"><strong class="text-success fs-5" data-field="netAmount">-</strong></p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Notes</label>
                    <p class="mb-0" data-field="notes">-</p>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/wages/details.js" asp-append-version="true"></script>
}
