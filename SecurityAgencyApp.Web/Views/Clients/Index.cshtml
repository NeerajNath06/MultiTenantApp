@model SecurityAgencyApp.Model.Api.ClientListResponse
@{
    ViewData["Title"] = "Clients";
    ViewData["Breadcrumbs"] = new[] { ("Clients", (string?)null) };
    var search = ViewBag.Search as string;
    var status = ViewBag.Status as string;
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="page-title">Clients</h1>
            <p class="page-subtitle mb-0">Manage client information</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Add New Client
        </a>
    </div>
</div>

<div class="row g-3 mb-4" id="clientsStats">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Clients</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Clients</div>
                <div class="stat-value" data-stat="active">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Suspended Clients</div>
                <div class="stat-value" data-stat="suspended">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden" id="clientsIndexPage"
     data-details-base="@Url.Action("Details", "Clients", new { id = "__id__" })"
     data-edit-base="@Url.Action("Edit", "Clients", new { id = "__id__" })"
     data-index-url="@Url.Action("Index", "Clients")">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search & Filters</h5>
    </div>
    <form method="get" action="@Url.Action("Index")" class="table-toolbar" id="clientsFilterForm">
        <div class="search-wrap">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" name="search" class="form-control border-start-0" placeholder="Search by name, code, email..." value="@search" />
            </div>
        </div>
        <select name="status" class="form-select form-select-sm" style="max-width: 140px;">
            <option value="">All statuses</option>
            @if (status == "Active") { <option value="Active" selected>Active</option> } else { <option value="Active">Active</option> }
            @if (status == "Inactive") { <option value="Inactive" selected>Inactive</option> } else { <option value="Inactive">Inactive</option> }
            @if (status == "Suspended") { <option value="Suspended" selected>Suspended</option> } else { <option value="Suspended">Suspended</option> }
        </select>
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="fas fa-filter me-1"></i>Apply
        </button>
        @if (!string.IsNullOrEmpty(search) || !string.IsNullOrEmpty(status))
        {
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm" id="clientsClearFilters">Clear</a>
        }
    </form>
    <div class="card-body p-0">
        <div class="px-4 py-3 border-bottom bg-body-tertiary d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="mb-0"><i class="fas fa-building me-2 text-primary"></i>Client Directory</h5>
            <span class="text-muted small" id="clientsRecordCount">0 total records</span>
        </div>
        <div id="clientsTableWrapper">
            <div class="text-center py-5">
                <i class="fas fa-building fa-3x text-muted mb-3 opacity-50"></i>
                <h5 class="text-muted">Loading clients...</h5>
                <p class="text-muted small mb-0">Fetching latest data from API.</p>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 px-4 py-3 border-top d-none" id="clientsPaginationContainer">
            <small class="text-muted" id="clientsPaginationSummary"></small>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0" id="clientsPagination"></ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/clients/index.js" asp-append-version="true"></script>
}
