@{
    ViewData["Title"] = "Client Details";
    var clientId = ViewBag.ClientId;
}

<div id="clientDetailsPage"
     data-client-id="@clientId"
     data-load-endpoint="Clients/@clientId"
     data-edit-url="@Url.Action("Edit", "Clients", new { id = clientId })"
     data-index-url="@Url.Action("Index", "Clients")">
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="page-title">Client Details</h1>
                <p class="page-subtitle mb-0">View client information</p>
            </div>
            <div>
                <a href="@Url.Action("Edit", new { id = clientId })" class="btn btn-primary">
                    <i class="fas fa-edit me-2"></i>Edit
                </a>
                <button type="button" class="btn btn-outline-danger" id="clientDeleteButton">
                    <i class="fas fa-trash me-2"></i>Delete
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm enterprise-details-card">
                <div class="card-body">
                    <div class="form-section">
                        <h5 class="section-title"><i class="fas fa-building"></i>Basic Information</h5>
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">Client Code</label>
                                <p class="mb-0" data-client-field="clientCode">-</p>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">Company Name</label>
                                <p class="mb-0" data-client-field="companyName">-</p>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">Contact Person</label>
                                <p class="mb-0" data-client-field="contactPerson">-</p>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">Status</label>
                                <p class="mb-0"><span class="badge bg-secondary" data-client-field="statusBadge">-</span></p>
                            </div>
                        </div>
                    </div>
                    <div class="form-section">
                        <h5 class="section-title"><i class="fas fa-address-book"></i>Contact & Address</h5>
                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">Email</label>
                                <p class="mb-0" data-client-field="email">-</p>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">Phone Number</label>
                                <p class="mb-0" data-client-field="phoneNumber">-</p>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">Alternate Phone</label>
                                <p class="mb-0" data-client-field="alternatePhone">-</p>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold text-muted">Address</label>
                                <p class="mb-0" data-client-field="address">-</p>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label fw-semibold text-muted">City</label>
                                <p class="mb-0" data-client-field="city">-</p>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label fw-semibold text-muted">State</label>
                                <p class="mb-0" data-client-field="state">-</p>
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label fw-semibold text-muted">Pin Code</label>
                                <p class="mb-0" data-client-field="pinCode">-</p>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">GST Number</label>
                                <p class="mb-0" data-client-field="gstNumber">-</p>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">PAN Number</label>
                                <p class="mb-0" data-client-field="panNumber">-</p>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">Website</label>
                                <p class="mb-0"><a href="#" target="_blank" rel="noopener noreferrer" data-client-field="websiteLink" class="d-none"></a><span data-client-field="websiteFallback">-</span></p>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label fw-semibold text-muted">Account Manager</label>
                                <p class="mb-0" data-client-field="accountManagerName">-</p>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold text-muted">Notes</label>
                                <p class="mb-0" data-client-field="notes">-</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm enterprise-details-card">
                <div class="card-body">
                    <h5 class="section-title"><i class="fas fa-info-circle"></i>Additional Information</h5>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold text-muted">Billing Address</label>
                            <p class="mb-0" data-client-field="billingAddress">-</p>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold text-muted">Billing City</label>
                            <p class="mb-0" data-client-field="billingCity">-</p>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold text-muted">Billing State</label>
                            <p class="mb-0" data-client-field="billingState">-</p>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label fw-semibold text-muted">Billing Pin Code</label>
                            <p class="mb-0" data-client-field="billingPinCode">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Billing Contact</label>
                            <p class="mb-0" data-client-field="billingContactName">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Billing Email</label>
                            <p class="mb-0" data-client-field="billingContactEmail">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Escalation Contact</label>
                            <p class="mb-0" data-client-field="escalationContactName">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Escalation Email</label>
                            <p class="mb-0" data-client-field="escalationContactEmail">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Escalation TAT</label>
                            <p class="mb-0" data-client-field="escalationTatHours">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Credit Period</label>
                            <p class="mb-0" data-client-field="creditPeriodDays">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Billing Cycle</label>
                            <p class="mb-0" data-client-field="billingCycle">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">GST State</label>
                            <p class="mb-0" data-client-field="gstState">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Payment Mode</label>
                            <p class="mb-0" data-client-field="paymentModePreference">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Invoice Prefix</label>
                            <p class="mb-0" data-client-field="invoicePrefix">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">SLA Terms</label>
                            <p class="mb-0" data-client-field="slaTerms">-</p>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label fw-semibold text-muted">Tax Treatment</label>
                            <p class="mb-0" data-client-field="taxTreatment">-</p>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold text-muted">Penalty Terms</label>
                            <p class="mb-0" data-client-field="penaltyTerms">-</p>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold text-muted">Created Date</label>
                            <p class="mb-0" data-client-field="createdDate">-</p>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold text-muted">Last Modified</label>
                            <p class="mb-0" data-client-field="modifiedDate">-</p>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold text-muted">Active</label>
                            <p class="mb-0"><span class="badge bg-secondary" data-client-field="activeBadge">-</span></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/clients/details.js" asp-append-version="true"></script>
}
