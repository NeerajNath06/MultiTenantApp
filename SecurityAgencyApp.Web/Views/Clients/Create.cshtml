@model SecurityAgencyApp.Web.Models.Api.CreateClientRequest
@{
    ViewData["Title"] = "Create Client";
    ViewData["Breadcrumbs"] = new[] { ("Clients", Url.Action("Index")), ("Create Client", (string?)null) };
}

<div class="page-header">
    <h1 class="page-title">Create Client</h1>
    <p class="page-subtitle mb-0">Add a new client to the system</p>
</div>

<div class="card border-0 shadow-sm enterprise-form-card">
    <div class="card-body">
        <form asp-action="Create" method="post" class="form">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="form-section">
                <h5 class="section-title">
                    <i class="fas fa-building"></i>Basic Information
                </h5>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="ClientCode" class="form-label fw-semibold">Client Code <span class="text-danger">*</span></label>
                    <input asp-for="ClientCode" class="form-control" required />
                    <span asp-validation-for="ClientCode" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="CompanyName" class="form-label fw-semibold">Company Name <span class="text-danger">*</span></label>
                    <input asp-for="CompanyName" class="form-control" required />
                    <span asp-validation-for="CompanyName" class="text-danger small"></span>
                </div>
            </div>
            </div>

            <div class="form-section">
                <h5 class="section-title">
                    <i class="fas fa-address-book"></i>Contact & Address
                </h5>
                <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="ContactPerson" class="form-label fw-semibold">Contact Person</label>
                    <input asp-for="ContactPerson" class="form-control" />
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="Status" class="form-label fw-semibold">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Active">Active</option>
                        <option value="Inactive">Inactive</option>
                        <option value="Suspended">Suspended</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-12 col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" type="email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-12 col-md-6">
                    <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-12">
                    <label asp-for="Address" class="form-label fw-semibold">Address <span class="text-danger">*</span></label>
                    <textarea asp-for="Address" class="form-control" rows="2" required></textarea>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
            </div>
            </div>

            <div class="form-section">
                <h5 class="section-title">
                    <i class="fas fa-map-marker-alt"></i>Location & Tax
                </h5>
                <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label asp-for="City" class="form-label fw-semibold">City</label>
                    <input asp-for="City" class="form-control" />
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="State" class="form-label fw-semibold">State</label>
                    <input asp-for="State" class="form-control" />
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="PinCode" class="form-label fw-semibold">Pin Code</label>
                    <input asp-for="PinCode" class="form-control" />
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-12 col-md-4">
                    <label asp-for="GSTNumber" class="form-label fw-semibold">GST Number</label>
                    <input asp-for="GSTNumber" class="form-control" />
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="PANNumber" class="form-label fw-semibold">PAN Number</label>
                    <input asp-for="PANNumber" class="form-control" />
                </div>
                <div class="col-12 col-md-4">
                    <label asp-for="Website" class="form-label fw-semibold">Website</label>
                    <input asp-for="Website" class="form-control" />
                </div>
            </div>
            </div>

            <div class="form-section">
                <h5 class="section-title">
                    <i class="fas fa-file-invoice"></i>Billing & Commercial
                </h5>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="BillingAddress" class="form-label fw-semibold">Billing Address</label>
                        <textarea asp-for="BillingAddress" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="BillingCity" class="form-label fw-semibold">Billing City</label>
                        <input asp-for="BillingCity" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="BillingState" class="form-label fw-semibold">Billing State</label>
                        <input asp-for="BillingState" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="BillingPinCode" class="form-label fw-semibold">Billing Pin Code</label>
                        <input asp-for="BillingPinCode" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="AccountManagerName" class="form-label fw-semibold">Account Manager</label>
                        <input asp-for="AccountManagerName" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="BillingContactName" class="form-label fw-semibold">Billing Contact</label>
                        <input asp-for="BillingContactName" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="BillingContactEmail" class="form-label fw-semibold">Billing Email</label>
                        <input asp-for="BillingContactEmail" type="email" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="EscalationContactName" class="form-label fw-semibold">Escalation Contact</label>
                        <input asp-for="EscalationContactName" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="EscalationContactEmail" class="form-label fw-semibold">Escalation Email</label>
                        <input asp-for="EscalationContactEmail" type="email" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="CreditPeriodDays" class="form-label fw-semibold">Credit Period (days)</label>
                        <input asp-for="CreditPeriodDays" type="number" class="form-control" />
                    </div>
                    <div class="col-12 col-md-3">
                        <label asp-for="BillingCycle" class="form-label fw-semibold">Billing Cycle</label>
                        <input asp-for="BillingCycle" class="form-control" />
                    </div>
                    <div class="col-12 col-md-3">
                        <label asp-for="GstState" class="form-label fw-semibold">GST State</label>
                        <input asp-for="GstState" class="form-control" />
                    </div>
                    <div class="col-12 col-md-3">
                        <label asp-for="PaymentModePreference" class="form-label fw-semibold">Payment Mode</label>
                        <input asp-for="PaymentModePreference" class="form-control" />
                    </div>
                    <div class="col-12 col-md-3">
                        <label asp-for="InvoicePrefix" class="form-label fw-semibold">Invoice Prefix</label>
                        <input asp-for="InvoicePrefix" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="TaxTreatment" class="form-label fw-semibold">Tax Treatment</label>
                        <input asp-for="TaxTreatment" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="EscalationTatHours" class="form-label fw-semibold">Escalation TAT (hours)</label>
                        <input asp-for="EscalationTatHours" type="number" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="SlaTerms" class="form-label fw-semibold">SLA Terms</label>
                        <input asp-for="SlaTerms" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="PenaltyTerms" class="form-label fw-semibold">Penalty Terms</label>
                        <textarea asp-for="PenaltyTerms" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5 class="section-title">
                    <i class="fas fa-sticky-note"></i>Notes
                </h5>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Create Client
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
