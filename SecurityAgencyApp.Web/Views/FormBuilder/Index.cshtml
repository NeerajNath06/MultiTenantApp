@model SecurityAgencyApp.Model.Api.FormTemplateListResponse
@{
    ViewData["Title"] = "Form Builder";
    var totalForms = Model?.Items?.Count ?? 0;
    var systemTemplates = Model?.Items?.Count(t => t.IsSystemTemplate) ?? 0;
    var totalSubmissions = Model?.Items?.Sum(t => t.SubmissionCount) ?? 0;
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Form Builder</h1>
            <p class="page-subtitle mb-0">Create and manage dynamic forms</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create New Form
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Forms</div>
                <div class="stat-value">@totalForms</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">System Templates</div>
                <div class="stat-value">@systemTemplates</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Submissions</div>
                <div class="stat-value">@totalSubmissions</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-file-alt me-2 text-primary"></i>Form Library</h5>
        <span class="text-muted small">@totalForms available templates</span>
    </div>
    <div class="card-body">
        @if (Model?.Items != null && Model.Items.Any())
        {
            <div class="row g-4">
                @foreach (var template in Model.Items)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h5 class="card-title mb-1">@template.Name</h5>
                                        <small class="text-muted">@template.Code</small>
                                    </div>
                                    @if (template.IsSystemTemplate)
                                    {
                                        <span class="badge bg-info">System</span>
                                    }
                                </div>
                                
                                @if (!string.IsNullOrEmpty(template.Description))
                                {
                                    <p class="card-text text-muted small mb-3">@template.Description</p>
                                }
                                
                                <div class="d-flex gap-2 mb-3">
                                    <span class="badge bg-secondary">
                                        <i class="fas fa-list me-1"></i>@template.FieldCount Fields
                                    </span>
                                    <span class="badge bg-primary">
                                        <i class="fas fa-file-alt me-1"></i>@template.SubmissionCount Submissions
                                    </span>
                                    @if (!string.IsNullOrEmpty(template.Category))
                                    {
                                        <span class="badge bg-success">@template.Category</span>
                                    }
                                </div>
                                
                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("Details", new { id = template.Id })" class="btn btn-sm btn-outline-info flex-fill">
                                        <i class="fas fa-eye me-1"></i>View
                                    </a>
                                    <a href="@Url.Action("Submit", new { id = template.Id })" class="btn btn-sm btn-outline-primary flex-fill">
                                        <i class="fas fa-paper-plane me-1"></i>Submit
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No forms found</h5>
                <p class="text-muted">Get started by creating your first form template.</p>
                <a href="@Url.Action("Create")" class="btn btn-primary mt-3">
                    <i class="fas fa-plus me-2"></i>Create New Form
                </a>
            </div>
        }
    </div>
</div>
