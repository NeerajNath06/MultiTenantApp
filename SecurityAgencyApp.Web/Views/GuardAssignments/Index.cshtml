@{
    ViewData["Title"] = "Guard Assignments";
    var supervisorId = string.Equals(Context.Session.GetString("IsSupervisor"), "True", StringComparison.OrdinalIgnoreCase)
        ? (Context.Session.GetString("UserId") ?? string.Empty)
        : string.Empty;
}

<div id="guardAssignmentsIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-supervisor-id="@supervisorId">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Guard Assignments</h1>
            <p class="page-subtitle mb-0">Manage guard assignments to sites</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Index", "Roster")" class="btn btn-outline-primary">
                <i class="fas fa-calendar-alt me-2"></i>View Roster
            </a>
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <i class="fas fa-user-check me-2"></i>Assign Guard
            </a>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Assignments</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Assignments</div>
                <div class="stat-value" data-stat="active">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Completed</div>
                <div class="stat-value" data-stat="completed">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search & Filters</h5>
    </div>
    <div class="card-body">
        <form id="guardAssignmentsFilterForm" method="get" class="row g-3">
            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="10" />
            <input type="hidden" name="sortBy" value="" />
            <input type="hidden" name="sortDirection" value="desc" />
            <div class="col-md-4">
                <label class="form-label">Filter by Guard</label>
                <select id="guardAssignmentsGuardId" name="guardId" class="form-select">
                    <option value="">All Guards</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Filter by Site</label>
                <select id="guardAssignmentsSiteId" name="siteId" class="form-select">
                    <option value="">All Sites</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">&nbsp;</label>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-2"></i>Filter
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-user-check me-2 text-primary"></i>Assignment Directory</h5>
        <span id="guardAssignmentsRecordCount" class="text-muted small">0 total records</span>
    </div>
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <span id="guardAssignmentsShowingSummary" class="text-muted">No assignments to display</span>
            </div>
            <div>
                <select id="guardAssignmentsPageSize" class="form-select form-select-sm d-inline-block" style="width: auto;">
                    <option value="10">10 per page</option>
                    <option value="25">25 per page</option>
                    <option value="50">50 per page</option>
                    <option value="100">100 per page</option>
                </select>
            </div>
        </div>
        <div id="guardAssignmentsTableWrapper"></div>
        <div id="guardAssignmentsPaginationContainer" class="d-none mt-4">
            <div id="guardAssignmentsPaginationSummary" class="text-muted small mb-2"></div>
            <ul id="guardAssignmentsPagination" class="pagination justify-content-center mb-0"></ul>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/guard-assignments/index.js" asp-append-version="true"></script>
}
