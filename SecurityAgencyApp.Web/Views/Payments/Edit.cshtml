@model SecurityAgencyApp.Model.Api.UpdatePaymentRequest
@{
    ViewData["Title"] = "Edit Payment";
}

<div class="page-header">
    <h1 class="page-title">Edit Payment</h1>
    <p class="page-subtitle mb-0">Update payment information</p>
</div>

<div id="paymentFormPage"
     data-mode="edit"
     data-load-endpoint="Payments/@Model.Id"
     data-submit-endpoint="Payments/@Model.Id"
     data-redirect-url="@Url.Action("Index")">
<div class="card border-0 shadow-sm enterprise-form-card">
    <div class="card-body">
        <form id="paymentForm" class="form">
            <input type="hidden" asp-for="Id" />
            <div id="paymentFormErrors" class="alert alert-danger d-none"></div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="PaymentNumber" class="form-label fw-semibold">Payment Number <span class="text-danger">*</span></label>
                    <input asp-for="PaymentNumber" class="form-control" required />
                    <span asp-validation-for="PaymentNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PaymentDate" class="form-label fw-semibold">Payment Date <span class="text-danger">*</span></label>
                    <input asp-for="PaymentDate" type="date" class="form-control" required />
                    <span asp-validation-for="PaymentDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="BillId" class="form-label fw-semibold">Bill</label>
                    <select asp-for="BillId" id="paymentBillId" class="form-select">
                        <option value="">Select Bill</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="ClientId" class="form-label fw-semibold">Client</label>
                    <select asp-for="ClientId" id="paymentClientId" class="form-select">
                        <option value="">Select Client</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Amount" class="form-label fw-semibold">Amount <span class="text-danger">*</span></label>
                    <input asp-for="Amount" type="number" step="0.01" class="form-control" required />
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="PaymentMethod" class="form-label fw-semibold">Payment Method</label>
                    <select asp-for="PaymentMethod" class="form-select">
                        <option value="Cash">Cash</option>
                        <option value="Cheque">Cheque</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="UPI">UPI</option>
                        <option value="Credit Card">Credit Card</option>
                        <option value="Debit Card">Debit Card</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Status" class="form-label fw-semibold">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option value="Pending">Pending</option>
                        <option value="Completed">Completed</option>
                        <option value="Failed">Failed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="ChequeNumber" class="form-label fw-semibold">Cheque Number</label>
                    <input asp-for="ChequeNumber" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="BankName" class="form-label fw-semibold">Bank Name</label>
                    <input asp-for="BankName" class="form-control" />
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="TransactionReference" class="form-label fw-semibold">Transaction Reference</label>
                    <input asp-for="TransactionReference" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ReceivedDate" class="form-label fw-semibold">Received Date</label>
                    <input asp-for="ReceivedDate" type="date" class="form-control" />
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" id="paymentFormSubmitButton" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Update Payment
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/payments/form.js" asp-append-version="true"></script>
}
