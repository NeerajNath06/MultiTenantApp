@model SecurityAgencyApp.Model.Api.DashboardDataDto
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Breadcrumbs"] = new[] { ("Dashboard", (string)null) };
    var tenantName = Context.Session.GetString("TenantName") ?? "Security Agency";
}

<div class="page-header">
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle mb-0">Welcome to <strong>@tenantName</strong>. Here's what's happening today.</p>
</div>

<!-- Statistics Cards -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label mb-2">Total Users</p>
                        <p class="stat-value mb-1">@Model.TotalUsers</p>
                        <small class="text-success">
                            <i class="fas fa-arrow-up me-1"></i>@Model.ActiveUsers Active
                        </small>
                    </div>
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label mb-2">Security Guards</p>
                        <p class="stat-value mb-1">@Model.TotalSecurityGuards</p>
                        <small class="text-success">
                            <i class="fas fa-arrow-up me-1"></i>@Model.ActiveGuards Active
                        </small>
                    </div>
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label mb-2">Departments</p>
                        <p class="stat-value mb-1">@Model.TotalDepartments</p>
                        <small class="text-muted">Active departments</small>
                    </div>
                    <div class="stat-icon bg-info bg-opacity-10 text-info">
                        <i class="fas fa-building"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label mb-2">Roles</p>
                        <p class="stat-value mb-1">@Model.TotalRoles</p>
                        <small class="text-muted">System roles</small>
                    </div>
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="fas fa-user-tag"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label mb-2">Menus</p>
                        <p class="stat-value mb-1">@Model.TotalMenus</p>
                        <small class="text-muted">Navigation items</small>
                    </div>
                    <div class="stat-icon bg-secondary bg-opacity-10 text-secondary">
                        <i class="fas fa-list"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label mb-2">Form Submissions</p>
                        <p class="stat-value mb-1">@Model.TotalFormSubmissions</p>
                        <small class="text-warning">
                            <i class="fas fa-clock me-1"></i>@Model.PendingFormSubmissions Pending
                        </small>
                    </div>
                    <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                        <i class="fas fa-file-alt"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts placeholder & Quick Actions -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0 fw-semibold">
                    <i class="fas fa-chart-line text-primary me-2"></i>Overview
                </h5>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 280px;">
                <div class="text-center text-muted py-4">
                    <i class="fas fa-chart-area fa-3x mb-3 opacity-50"></i>
                    <p class="mb-0">Chart area – integrate Chart.js or your preferred library</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0 fw-semibold">
                    <i class="fas fa-bolt text-warning me-2"></i>Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="d-flex flex-column gap-2">
                    <a href="@Url.Action("Create", "Users")" class="btn btn-primary btn-sm d-flex align-items-center gap-2">
                        <i class="fas fa-user-plus"></i><span>Add User</span>
                    </a>
                    <a href="@Url.Action("Create", "Departments")" class="btn btn-outline-info btn-sm d-flex align-items-center gap-2">
                        <i class="fas fa-building"></i><span>Add Department</span>
                    </a>
                    <a href="@Url.Action("Create", "Roles")" class="btn btn-outline-warning btn-sm d-flex align-items-center gap-2">
                        <i class="fas fa-user-tag"></i><span>Add Role</span>
                    </a>
                    <a href="@Url.Action("Create", "Clients")" class="btn btn-outline-success btn-sm d-flex align-items-center gap-2">
                        <i class="fas fa-building"></i><span>Add Client</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activities -->
@if (Model.RecentActivities != null && Model.RecentActivities.Any())
{
    <div class="row g-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-semibold">
                        <i class="fas fa-history text-primary me-2"></i>Recent Activity
                    </h5>
                    <a href="#" class="btn btn-sm btn-outline-primary">View all</a>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var activity in Model.RecentActivities)
                        {
                            <div class="list-group-item border-0 border-bottom py-3 px-4">
                                <div class="d-flex w-100 justify-content-between align-items-start gap-2">
                                    <div class="flex-grow-1 min-width-0">
                                        <h6 class="mb-1 fw-semibold">@activity.Description</h6>
                                        <small class="text-muted">
                                            <i class="fas fa-user me-1"></i>@activity.UserName
                                        </small>
                                    </div>
                                    <small class="text-muted text-nowrap">
                                        <i class="fas fa-clock me-1"></i>@activity.ActivityDate.ToString("dd MMM yyyy HH:mm")
                                    </small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Chart placeholder – e.g. Chart.js: new Chart(ctx, { type: 'line', data: {...} });
    </script>
}
