@{
    ViewData["Title"] = "Dashboard";
    ViewData["Breadcrumbs"] = new[] { ("Dashboard", (string?)null) };
    var tenantName = Context.Session.GetString("TenantName") ?? "Security Agency";
}

<div id="dashboardPage" data-endpoint="Dashboard">
    <div class="page-header">
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle mb-0">Welcome to <strong>@tenantName</strong>. Here's what's happening today.</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="stat-label mb-2">Total Users</p>
                            <p class="stat-value mb-1" data-dashboard-field="totalUsers">0</p>
                            <small class="text-success">
                                <i class="fas fa-arrow-up me-1"></i><span data-dashboard-field="activeUsers">0</span> Active
                            </small>
                        </div>
                        <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="stat-label mb-2">Security Guards</p>
                            <p class="stat-value mb-1" data-dashboard-field="totalSecurityGuards">0</p>
                            <small class="text-success">
                                <i class="fas fa-arrow-up me-1"></i><span data-dashboard-field="activeGuards">0</span> Active
                            </small>
                        </div>
                        <div class="stat-icon bg-success bg-opacity-10 text-success">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="stat-label mb-2">Departments</p>
                            <p class="stat-value mb-1" data-dashboard-field="totalDepartments">0</p>
                            <small class="text-muted">Active departments</small>
                        </div>
                        <div class="stat-icon bg-info bg-opacity-10 text-info">
                            <i class="fas fa-building"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="stat-label mb-2">Roles</p>
                            <p class="stat-value mb-1" data-dashboard-field="totalRoles">0</p>
                            <small class="text-muted">System roles</small>
                        </div>
                        <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                            <i class="fas fa-user-tag"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="stat-label mb-2">Menus</p>
                            <p class="stat-value mb-1" data-dashboard-field="totalMenus">0</p>
                            <small class="text-muted">Navigation items</small>
                        </div>
                        <div class="stat-icon bg-secondary bg-opacity-10 text-secondary">
                            <i class="fas fa-list"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="stat-label mb-2">Form Submissions</p>
                            <p class="stat-value mb-1" data-dashboard-field="totalFormSubmissions">0</p>
                            <small class="text-warning">
                                <i class="fas fa-clock me-1"></i><span data-dashboard-field="pendingFormSubmissions">0</span> Pending
                            </small>
                        </div>
                        <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                            <i class="fas fa-file-alt"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 fw-semibold">
                        <i class="fas fa-chart-line text-primary me-2"></i>Overview
                    </h5>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 280px;">
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-chart-area fa-3x mb-3 opacity-50"></i>
                        <p class="mb-0">Chart area - integrate Chart.js or your preferred library</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 fw-semibold">
                        <i class="fas fa-bolt text-warning me-2"></i>Quick Actions
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-column gap-2">
                        <a href="@Url.Action("Create", "Users")" class="btn btn-primary btn-sm d-flex align-items-center gap-2">
                            <i class="fas fa-user-plus"></i><span>Add User</span>
                        </a>
                        <a href="@Url.Action("Create", "Departments")" class="btn btn-outline-info btn-sm d-flex align-items-center gap-2">
                            <i class="fas fa-building"></i><span>Add Department</span>
                        </a>
                        <a href="@Url.Action("Create", "Roles")" class="btn btn-outline-warning btn-sm d-flex align-items-center gap-2">
                            <i class="fas fa-user-tag"></i><span>Add Role</span>
                        </a>
                        <a href="@Url.Action("Create", "Clients")" class="btn btn-outline-success btn-sm d-flex align-items-center gap-2">
                            <i class="fas fa-building"></i><span>Add Client</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-semibold">
                        <i class="fas fa-history text-primary me-2"></i>Recent Activity
                    </h5>
                    <span class="btn btn-sm btn-outline-primary disabled">Live API feed</span>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush" id="dashboardRecentActivities">
                        <div class="list-group-item border-0 py-4 px-4 text-muted">Loading dashboard activity...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/home/index.js" asp-append-version="true"></script>
}
