@model SecurityAgencyApp.Web.Models.Api.SiteDto
@{
    ViewData["Title"] = "Site Details";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="page-title">Site Details</h1>
            <p class="page-subtitle mb-0">@Model.SiteName - @Model.SiteCode</p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <a href="@Url.Action("Index", "SitePosts", new { siteId = Model.Id })" class="btn btn-outline-primary">
                <i class="fas fa-users-cog me-2"></i>Site Posts
            </a>
            <a href="@Url.Action("Index", "SiteRates", new { siteId = Model.Id })" class="btn btn-outline-info">
                <i class="fas fa-rupee-sign me-2"></i>Rate Management
            </a>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Sites
            </a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-map-marker-alt"></i>Site Information</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Site Code</label>
                        <p class="mb-0"><span class="badge bg-secondary">@Model.SiteCode</span></p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Client</label>
                        <p class="mb-0">@(string.IsNullOrWhiteSpace(Model.ClientName) ? "-" : Model.ClientName)</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Branch</label>
                        <p class="mb-0">@(string.IsNullOrWhiteSpace(Model.BranchName) ? "-" : Model.BranchName)</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Address</label>
                        <p class="mb-0">@Model.Address</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">City</label>
                        <p class="mb-0">@Model.City</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">State</label>
                        <p class="mb-0">@Model.State</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Pin Code</label>
                        <p class="mb-0">@Model.PinCode</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm enterprise-details-card mt-4">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-address-book"></i>Contact & Operations</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Contact Person</label>
                        <p class="mb-0">@(Model.ContactPerson ?? "-")</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Contact Phone</label>
                        <p class="mb-0">@(Model.ContactPhone ?? "-")</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Contact Email</label>
                        <p class="mb-0">@(Model.ContactEmail ?? "-")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Assigned Supervisors</label>
                        <p class="mb-0">@Model.SupervisorIds.Count</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Status</label>
                        <p class="mb-0">
                            <span class="badge bg-@(Model.IsActive ? "success" : "danger")">
                                @(Model.IsActive ? "Active" : "Inactive")
                            </span>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Emergency Contact</label>
                        <p class="mb-0">@(string.IsNullOrWhiteSpace(Model.EmergencyContactName) ? "-" : $"{Model.EmergencyContactName} ({Model.EmergencyContactPhone ?? "-"})")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Muster Point</label>
                        <p class="mb-0">@(Model.MusterPoint ?? "-")</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Access Zones</label>
                        <p class="mb-0">@(Model.AccessZoneNotes ?? "-")</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Site Instruction Book</label>
                        <p class="mb-0">@(Model.SiteInstructionBook ?? "-")</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Geofence Exception Notes</label>
                        <p class="mb-0">@(Model.GeofenceExceptionNotes ?? "-")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-crosshairs"></i>Geofence</h5>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Latitude</label>
                    <p class="mb-0">@(Model.Latitude?.ToString() ?? "-")</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Longitude</label>
                    <p class="mb-0">@(Model.Longitude?.ToString() ?? "-")</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Radius (meters)</label>
                    <p class="mb-0">@(Model.GeofenceRadiusMeters?.ToString() ?? "-")</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Created Date</label>
                    <p class="mb-0">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</p>
                </div>
                @if (Model.ModifiedDate.HasValue)
                {
                    <div class="mb-0">
                        <label class="form-label fw-semibold text-muted">Last Modified</label>
                        <p class="mb-0">@Model.ModifiedDate.Value.ToString("dd MMM yyyy HH:mm")</p>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm enterprise-details-card mt-4">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-users-cog"></i>Deployment Planning</h5>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Site Posts</label>
                    @if (Model.Posts.Count == 0)
                    {
                        <p class="mb-0">-</p>
                    }
                    else
                    {
                        <ul class="mb-0 ps-3">
                            @foreach (var post in Model.Posts)
                            {
                                <li>@post.PostCode - @post.PostName (@post.SanctionedStrength)</li>
                            }
                        </ul>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Deployment Plan</label>
                    <p class="mb-0">@(Model.ActiveDeploymentPlan?.InstructionSummary ?? "-")</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Effective Window</label>
                    <p class="mb-0">
                        @(Model.ActiveDeploymentPlan == null
                            ? "-"
                            : $"{Model.ActiveDeploymentPlan.EffectiveFrom:dd MMM yyyy} - {(Model.ActiveDeploymentPlan.EffectiveTo.HasValue ? Model.ActiveDeploymentPlan.EffectiveTo.Value.ToString("dd MMM yyyy") : "Open")}")
                    </p>
                </div>
                <div class="mb-0">
                    <label class="form-label fw-semibold text-muted">Reserve Pool / Zones</label>
                    <p class="mb-0">@(string.IsNullOrWhiteSpace(Model.ActiveDeploymentPlan?.ReservePoolMapping) && string.IsNullOrWhiteSpace(Model.ActiveDeploymentPlan?.AccessZones) ? "-" : $"{Model.ActiveDeploymentPlan?.ReservePoolMapping ?? "-"} | {Model.ActiveDeploymentPlan?.AccessZones ?? "-"}")</p>
                </div>
            </div>
        </div>
    </div>
</div>
