@{
    ViewData["Title"] = "Site Details";
    var siteId = ViewBag.SiteId;
}

<div id="siteDetailsPage"
     data-site-id="@siteId"
     data-load-endpoint="Sites/@siteId">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="page-title">Site Details</h1>
            <p class="page-subtitle mb-0"><span data-field="siteName">-</span> - <span data-field="siteCodeText">-</span></p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Edit", new { id = siteId })" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <a href="@Url.Action("Index", "SitePosts", new { siteId = siteId })" class="btn btn-outline-primary">
                <i class="fas fa-users-cog me-2"></i>Site Posts
            </a>
            <a href="@Url.Action("Index", "SiteRates", new { siteId = siteId })" class="btn btn-outline-info">
                <i class="fas fa-rupee-sign me-2"></i>Rate Management
            </a>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to Sites
            </a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-map-marker-alt"></i>Site Information</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Site Code</label>
                        <p class="mb-0"><span class="badge bg-secondary" data-field="siteCode">-</span></p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Client</label>
                        <p class="mb-0" data-field="clientName">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Branch</label>
                        <p class="mb-0" data-field="branchName">-</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Address</label>
                        <p class="mb-0" data-field="address">-</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">City</label>
                        <p class="mb-0" data-field="city">-</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">State</label>
                        <p class="mb-0" data-field="state">-</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Pin Code</label>
                        <p class="mb-0" data-field="pinCode">-</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm enterprise-details-card mt-4">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-address-book"></i>Contact & Operations</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Contact Person</label>
                        <p class="mb-0" data-field="contactPerson">-</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Contact Phone</label>
                        <p class="mb-0" data-field="contactPhone">-</p>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold text-muted">Contact Email</label>
                        <p class="mb-0" data-field="contactEmail">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Assigned Supervisors</label>
                        <p class="mb-0" data-field="supervisorCount">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Status</label>
                        <p class="mb-0">
                            <span class="badge bg-secondary" data-field="statusBadge">-</span>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Emergency Contact</label>
                        <p class="mb-0" data-field="emergencyContact">-</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold text-muted">Muster Point</label>
                        <p class="mb-0" data-field="musterPoint">-</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Access Zones</label>
                        <p class="mb-0" data-field="accessZoneNotes">-</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Site Instruction Book</label>
                        <p class="mb-0" data-field="siteInstructionBook">-</p>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold text-muted">Geofence Exception Notes</label>
                        <p class="mb-0" data-field="geofenceExceptionNotes">-</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm enterprise-details-card">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-crosshairs"></i>Geofence</h5>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Latitude</label>
                    <p class="mb-0" data-field="latitude">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Longitude</label>
                    <p class="mb-0" data-field="longitude">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Radius (meters)</label>
                    <p class="mb-0" data-field="geofenceRadiusMeters">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Created Date</label>
                    <p class="mb-0" data-field="createdDate">-</p>
                </div>
                <div class="mb-0">
                    <label class="form-label fw-semibold text-muted">Last Modified</label>
                    <p class="mb-0" data-field="modifiedDate">-</p>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm enterprise-details-card mt-4">
            <div class="card-body">
                <h5 class="section-title"><i class="fas fa-users-cog"></i>Deployment Planning</h5>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Site Posts</label>
                    <div id="sitePostsList" class="mb-0">-</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Deployment Plan</label>
                    <p class="mb-0" data-field="planInstructionSummary">-</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Effective Window</label>
                    <p class="mb-0" data-field="planWindow">-</p>
                </div>
                <div class="mb-0">
                    <label class="form-label fw-semibold text-muted">Reserve Pool / Zones</label>
                    <p class="mb-0" data-field="reserveZones">-</p>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/sites/details.js" asp-append-version="true"></script>
}
