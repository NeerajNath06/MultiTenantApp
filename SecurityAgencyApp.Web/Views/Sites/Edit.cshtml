@model SecurityAgencyApp.Model.Api.UpdateSiteRequest
@{
    ViewData["Title"] = "Edit Site";
}

<div class="page-header">
    <h1 class="page-title">Edit Site</h1>
    <p class="page-subtitle mb-0">Update site information</p>
</div>

<div id="siteFormPage"
     data-mode="edit"
     data-site-id="@Model.Id"
     data-load-endpoint="Sites/@Model.Id"
     data-submit-endpoint="Sites/@Model.Id"
     data-redirect-url="@Url.Action("Index")">
<div class="card border-0 shadow-sm enterprise-form-card">
    <div class="card-body">
        <form class="form" id="siteForm">
            <div id="siteFormErrors" class="alert alert-danger d-none"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ClientName" />

            <div class="form-section">
                <h5 class="section-title"><i class="fas fa-map-marker-alt"></i>Site Details</h5>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="SiteCode" class="form-label fw-semibold">Site Code <span class="text-danger">*</span></label>
                        <input asp-for="SiteCode" class="form-control" required />
                        <span asp-validation-for="SiteCode" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="SiteName" class="form-label fw-semibold">Site Name <span class="text-danger">*</span></label>
                        <input asp-for="SiteName" class="form-control" required />
                        <span asp-validation-for="SiteName" class="text-danger small"></span>
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-12 col-md-6">
                        <label asp-for="ClientId" class="form-label fw-semibold">Client (link for billing)</label>
                        <select asp-for="ClientId" class="form-select" id="siteClientIdDropdown">
                            <option value="">-- Select Client --</option>
                        </select>
                        <span class="small text-muted">Select client for this site; required before saving rate. Only clients that have this site in their contract are listed.</span>
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-12">
                        <label asp-for="Address" class="form-label fw-semibold">Address <span class="text-danger">*</span></label>
                        <input asp-for="Address" class="form-control" required />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-12 col-md-4">
                        <label asp-for="City" class="form-label fw-semibold">City <span class="text-danger">*</span></label>
                        <input asp-for="City" class="form-control" required />
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="State" class="form-label fw-semibold">State <span class="text-danger">*</span></label>
                        <input asp-for="State" class="form-control" required />
                        <span asp-validation-for="State" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="PinCode" class="form-label fw-semibold">Pin Code <span class="text-danger">*</span></label>
                        <input asp-for="PinCode" class="form-control" required />
                        <span asp-validation-for="PinCode" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5 class="section-title"><i class="fas fa-address-book"></i>Contact</h5>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="ContactPerson" class="form-label fw-semibold">Contact Person <span class="text-danger">*</span></label>
                        <input asp-for="ContactPerson" class="form-control" required />
                        <span asp-validation-for="ContactPerson" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="ContactPhone" class="form-label fw-semibold">Contact Phone <span class="text-danger">*</span></label>
                        <input asp-for="ContactPhone" class="form-control" required />
                        <span asp-validation-for="ContactPhone" class="text-danger small"></span>
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-12 col-md-6">
                        <label asp-for="ContactEmail" class="form-label fw-semibold">Contact Email</label>
                        <input asp-for="ContactEmail" type="email" class="form-control" />
                        <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="form-check mt-4">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5 class="section-title"><i class="fas fa-user-tie"></i>Site Supervisors</h5>
                <p class="small text-muted mb-3">Assign supervisors to this site. They will see only this site and its guards when logged in.</p>
                <div class="row g-3">
                    <div class="col-12">
                        <div class="dropdown">
                            <button type="button" class="form-select form-control text-start d-flex align-items-center" id="siteSupervisorsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="siteSupervisorsLabel">-- Select Supervisors --</span>
                                <i class="fas fa-chevron-down ms-auto"></i>
                            </button>
                            <ul class="dropdown-menu w-100 px-2" id="siteSupervisorsMenu" style="max-height: 220px; overflow-y: auto;"></ul>
                            <div id="siteSupervisorsHiddenContainer"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5 class="section-title"><i class="fas fa-map-pin"></i>Location &amp; Geofence</h5>
                <p class="small text-muted mb-3">Set site center and radius so guards can check-in only when within range. Get coordinates from Google Maps (right-click on map → coordinates).</p>
                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label asp-for="Latitude" class="form-label fw-semibold">Latitude</label>
                        <input asp-for="Latitude" type="number" step="any" class="form-control" placeholder="e.g. 28.6139" />
                        <span asp-validation-for="Latitude" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="Longitude" class="form-label fw-semibold">Longitude</label>
                        <input asp-for="Longitude" type="number" step="any" class="form-control" placeholder="e.g. 77.2090" />
                        <span asp-validation-for="Longitude" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="GeofenceRadiusMeters" class="form-label fw-semibold">Geofence radius (meters)</label>
                        <input asp-for="GeofenceRadiusMeters" type="number" min="0" class="form-control" placeholder="e.g. 100" />
                        <span asp-validation-for="GeofenceRadiusMeters" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5 class="section-title"><i class="fas fa-shield-alt"></i>Operations & Emergency</h5>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="EmergencyContactName" class="form-label fw-semibold">Emergency Contact Name</label>
                        <input asp-for="EmergencyContactName" class="form-control" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="EmergencyContactPhone" class="form-label fw-semibold">Emergency Contact Phone</label>
                        <input asp-for="EmergencyContactPhone" class="form-control" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="MusterPoint" class="form-label fw-semibold">Muster Point</label>
                        <input asp-for="MusterPoint" class="form-control" />
                    </div>
                    <div class="col-12 col-md-8">
                        <label asp-for="AccessZoneNotes" class="form-label fw-semibold">Access Zones</label>
                        <input asp-for="AccessZoneNotes" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="SiteInstructionBook" class="form-label fw-semibold">Site Instruction Book</label>
                        <textarea asp-for="SiteInstructionBook" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="col-12">
                        <label asp-for="GeofenceExceptionNotes" class="form-label fw-semibold">Geofence Exception Notes</label>
                        <textarea asp-for="GeofenceExceptionNotes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <partial name="_SitePlanningEditor" model="Model" />

            <div class="form-actions">
                <button type="submit" class="btn btn-primary" id="siteFormSubmitButton" data-default-text="Update Site">
                    <i class="fas fa-save me-2"></i>Update Site
                </button>
                <button type="button" class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#generateReportModal">
                    <i class="fas fa-file-alt me-2"></i>Generate Report
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>
</div>

<!-- Rate plan: separate form so "Save Rate" does not submit the site form -->
<div class="card border-0 shadow-sm enterprise-form-card mt-4">
    <div class="card-body">
        <h5 class="section-title"><i class="fas fa-rupee-sign"></i>Billing Rate &amp; Wages (Per Day)</h5>
        <p class="small text-muted mb-3">Per-day rate aur wages ke liye EPF/ESIC/Allowance % + EPF cap set karein. <b>Save Rate</b> dabane se ye sab save ho jate hain — Wages sheet me <b>Total Deduction</b> = EPF deduction + ESIC deduction inhi % se nikalti hai.</p>
        <div class="row g-3 align-items-end">
            <div class="col-6 col-lg-3">
                <label class="form-label fw-semibold">Current Rate</label>
                <input type="text" class="form-control" id="siteRateCurrentRate" value="Not set" readonly />
            </div>
            <div class="col-6 col-lg-3">
                <label class="form-label fw-semibold">For Client</label>
                <input type="text" class="form-control" id="siteRateCurrentClient" value="-" readonly />
            </div>
            <div class="col-6 col-lg-3">
                <label class="form-label fw-semibold">Effective From</label>
                <input type="date" class="form-control" id="rateEffectiveFrom" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-6 col-lg-3">
                <label class="form-label fw-semibold">New Rate (₹)</label>
                <input type="number" step="0.01" min="0" class="form-control" id="rateAmount" placeholder="e.g. 500" />
            </div>
        </div>
        <div class="row g-3 align-items-end mt-0">
            <div class="col-6 col-lg-3">
                <label class="form-label fw-semibold">EPF %</label>
                <input type="number" step="0.01" min="0" max="100" class="form-control" id="rateEpfPercent" placeholder="e.g. 12" title="Deduction of EPF @@ 12%" />
            </div>
            <div class="col-6 col-lg-3">
                <label class="form-label fw-semibold">ESIC %</label>
                <input type="number" step="0.01" min="0" max="100" class="form-control" id="rateEsicPercent" placeholder="e.g. 0.75" title="Deduction of ESIC @@ .75%" />
            </div>
            <div class="col-6 col-lg-3">
                <label class="form-label fw-semibold">Allowance %</label>
                <input type="number" step="0.01" min="0" max="100" class="form-control" id="rateAllowancePercent" placeholder="0" />
            </div>
            <div class="col-6 col-lg-3">
                <label class="form-label fw-semibold">EPF Wage Cap (₹)</label>
                <input type="number" step="1" min="0" class="form-control" id="rateEpfWageCap" placeholder="e.g. 15000" title="Epf Wages @@ 15000 - cap for EPF calculation" />
            </div>
        </div>
        <div class="row g-3 align-items-end mt-0">
            <div class="col-12 col-md-4">
                <button type="button" class="btn btn-primary" id="saveSiteRateButton">
                    <i class="fas fa-save me-2"></i>Save Rate
                </button>
                <span class="small text-muted ms-2">(Rate + EPF/ESIC/Allowance % + EPF cap sab save honge)</span>
            </div>
        </div>
        <div id="siteRateValidationMessage" class="alert alert-danger d-none mt-3 mb-0"></div>
        <div class="mt-4">
            <label class="form-label fw-semibold">Rate plans (Edit = update in place, Delete = deactivate)</label>
            <div id="siteRateHistoryWrapper"></div>
        </div>
        <p class="small text-muted mt-2 mb-0">Tip: Pehle client select karein, phir rate + EPF/ESIC % + EPF cap daal kar <b>Save Rate</b> dabayein. Wages sheet me <b>Total Deduction</b> = EPF @@ % + ESIC @@ % inhi values se aayegi. Kisi plan ko update karne ke liye list me <b>Edit</b> dabayein.</p>
    </div>
</div>

<!-- Generate Report Modal -->
<div class="modal fade" id="generateReportModal" tabindex="-1" aria-labelledby="generateReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="generateReportModalLabel"><i class="fas fa-file-alt me-2"></i>Generate Monthly Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="reportYear" class="form-label fw-semibold">Year</label>
                    <select id="reportYear" class="form-select"></select>
                </div>
                <div class="mb-3">
                    <label for="reportMonth" class="form-label fw-semibold">Month</label>
                    <select id="reportMonth" class="form-select">
                        <option value="1">January</option>
                        <option value="2">February</option>
                        <option value="3">March</option>
                        <option value="4">April</option>
                        <option value="5">May</option>
                        <option value="6">June</option>
                        <option value="7">July</option>
                        <option value="8">August</option>
                        <option value="9">September</option>
                        <option value="10">October</option>
                        <option value="11">November</option>
                        <option value="12">December</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label for="reportFormat" class="form-label fw-semibold">Format</label>
                    <select id="reportFormat" class="form-select">
                        <option value="Excel">Excel</option>
                        <option value="PDF">PDF</option>
                    </select>
                </div>
                <div id="reportTracking" class="alert alert-secondary d-none">
                    <div class="fw-semibold mb-1">Tracking</div>
                    <div class="small">Bill ID: <span id="trackBillId">-</span></div>
                    <div class="small">Wage ID: <span id="trackWageId">-</span></div>
                </div>
                <div id="reportMessage" class="alert d-none mb-0" role="alert"></div>
            </div>
            <div class="modal-footer flex-wrap">
                <button type="button" class="btn btn-primary report-btn" data-report-type="bill">
                    <i class="fas fa-file-invoice-dollar me-1"></i>Generate Bill
                </button>
                <button type="button" class="btn btn-primary report-btn" data-report-type="attendance">
                    <i class="fas fa-clipboard-list me-1"></i>Generate Attendance
                </button>
                <button type="button" class="btn btn-primary report-btn" data-report-type="wages">
                    <i class="fas fa-money-bill-wave me-1"></i>Generate Wages
                </button>
                <button type="button" class="btn btn-success report-btn" data-report-type="full">
                    <i class="fas fa-file-archive me-1"></i>Generate All
                </button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/sites/form.js" asp-append-version="true"></script>
}
