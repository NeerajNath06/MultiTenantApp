@{
    ViewData["Title"] = "Sites";
    var supervisorId = ViewBag.SupervisorId;
}

<div id="sitesIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-details-base="@Url.Action("Details", new { id = "__id__" })"
     data-edit-base="@Url.Action("Edit", new { id = "__id__" })"
     data-supervisor-id="@supervisorId">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Sites</h1>
            <p class="page-subtitle mb-0">Manage client sites</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-building me-2"></i>Add New Site
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Sites</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Sites</div>
                <div class="stat-value" data-stat="active">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Plans</div>
                <div class="stat-value" data-stat="plans">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search & Filters</h5>
    </div>
    <div class="card-body">
        <form id="sitesFilterForm" class="row g-3">
            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" id="sitesSortBy" name="sortBy" value="" />
            <input type="hidden" id="sitesSortDirection" name="sortDirection" value="asc" />
            <div class="col-md-10">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" id="sitesSearch" name="search" class="form-control" placeholder="Search by site name, code, client, city..." />
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-2"></i>Search
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-building me-2 text-primary"></i>Site Directory</h5>
        <div class="d-flex align-items-center gap-2">
            <span id="sitesRecordCount" class="text-muted small">0 total records</span>
            <select id="sitesPageSize" class="form-select form-select-sm" style="width: auto;">
                <option value="10">10 per page</option>
                <option value="25">25 per page</option>
                <option value="50">50 per page</option>
                <option value="100">100 per page</option>
            </select>
        </div>
    </div>
    <div class="card-body">
        <div id="sitesTableWrapper"></div>
        <div id="sitesPaginationContainer" class="mt-4 d-none">
            <div id="sitesPaginationSummary" class="text-muted text-center small mb-2"></div>
            <ul id="sitesPagination" class="pagination justify-content-center"></ul>
        </div>
    </div>
</div>
</div>

<!-- Generate Report Modal (for Index page) -->
<div class="modal fade" id="generateReportModal" tabindex="-1" aria-labelledby="generateReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="generateReportModalLabel"><i class="fas fa-file-alt me-2"></i>Generate Monthly Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="reportSiteId" value="" />
                <div class="mb-3">
                    <label for="reportYear" class="form-label fw-semibold">Year</label>
                    <select id="reportYear" class="form-select"></select>
                </div>
                <div class="mb-3">
                    <label for="reportMonth" class="form-label fw-semibold">Month</label>
                    <select id="reportMonth" class="form-select">
                        <option value="1">January</option>
                        <option value="2">February</option>
                        <option value="3">March</option>
                        <option value="4">April</option>
                        <option value="5">May</option>
                        <option value="6">June</option>
                        <option value="7">July</option>
                        <option value="8">August</option>
                        <option value="9">September</option>
                        <option value="10">October</option>
                        <option value="11">November</option>
                        <option value="12">December</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label for="reportFormat" class="form-label fw-semibold">Format</label>
                    <select id="reportFormat" class="form-select">
                        <option value="Excel">Excel</option>
                        <option value="PDF">PDF</option>
                    </select>
                </div>
                <div id="reportTracking" class="alert alert-secondary d-none">
                    <div class="fw-semibold mb-1">Tracking</div>
                    <div class="small">Bill ID: <span id="trackBillId">-</span></div>
                    <div class="small">Wage ID: <span id="trackWageId">-</span></div>
                </div>
                <div id="reportMessage" class="alert d-none mb-0" role="alert"></div>
            </div>
            <div class="modal-footer flex-wrap">
                <button type="button" class="btn btn-primary report-btn" data-report-type="bill"><i class="fas fa-file-invoice-dollar me-1"></i>Generate Bill</button>
                <button type="button" class="btn btn-primary report-btn" data-report-type="attendance"><i class="fas fa-clipboard-list me-1"></i>Generate Attendance</button>
                <button type="button" class="btn btn-primary report-btn" data-report-type="wages"><i class="fas fa-money-bill-wave me-1"></i>Generate Wages</button>
                <button type="button" class="btn btn-success report-btn" data-report-type="full"><i class="fas fa-file-archive me-1"></i>Generate All</button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/sites/index.js" asp-append-version="true"></script>
}
