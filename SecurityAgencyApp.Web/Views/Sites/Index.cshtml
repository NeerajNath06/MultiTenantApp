@model SecurityAgencyApp.Web.Models.Api.SiteListResponse
@{
    ViewData["Title"] = "Sites";
    var currentSort = Model?.SortBy ?? "";
    var currentDirection = Model?.SortDirection ?? "asc";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Sites</h1>
            <p class="page-subtitle mb-0">Manage client sites</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-building me-2"></i>Add New Site
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="@(Model?.PageSize ?? 10)" />
            <input type="hidden" name="sortBy" value="@currentSort" />
            <input type="hidden" name="sortDirection" value="@currentDirection" />
            <div class="col-md-10">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Search by site name, code, client, city..." value="@Model?.Search" />
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-2"></i>Search
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if (Model?.Items != null && Model.Items.Any())
        {
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <span class="text-muted">Showing @((Model.PageNumber - 1) * Model.PageSize + 1) to @(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)) of @Model.TotalCount sites</span>
                </div>
                <div>
                    <select class="form-select form-select-sm d-inline-block" style="width: auto;" onchange="changePageSize(this.value)">
                        <option value="10" selected="@(Model.PageSize == 10)">10 per page</option>
                        <option value="25" selected="@(Model.PageSize == 25)">25 per page</option>
                        <option value="50" selected="@(Model.PageSize == 50)">50 per page</option>
                        <option value="100" selected="@(Model.PageSize == 100)">100 per page</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>
                                <a href="@Url.Action("Index", new { pageNumber = Model.PageNumber, pageSize = Model.PageSize, search = Model.Search, sortBy = "code", sortDirection = currentSort == "code" && currentDirection == "asc" ? "desc" : "asc" })" class="text-decoration-none text-dark">
                                    Site Code
                                    @if (currentSort == "code")
                                    {
                                        <i class="fas fa-sort-@(currentDirection == "asc" ? "up" : "down")"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-sort text-muted"></i>
                                    }
                                </a>
                            </th>
                            <th>
                                <a href="@Url.Action("Index", new { pageNumber = Model.PageNumber, pageSize = Model.PageSize, search = Model.Search, sortBy = "name", sortDirection = currentSort == "name" && currentDirection == "asc" ? "desc" : "asc" })" class="text-decoration-none text-dark">
                                    Site Name
                                    @if (currentSort == "name")
                                    {
                                        <i class="fas fa-sort-@(currentDirection == "asc" ? "up" : "down")"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-sort text-muted"></i>
                                    }
                                </a>
                            </th>
                            <th>
                                <a href="@Url.Action("Index", new { pageNumber = Model.PageNumber, pageSize = Model.PageSize, search = Model.Search, sortBy = "client", sortDirection = currentSort == "client" && currentDirection == "asc" ? "desc" : "asc" })" class="text-decoration-none text-dark">
                                    Client
                                    @if (currentSort == "client")
                                    {
                                        <i class="fas fa-sort-@(currentDirection == "asc" ? "up" : "down")"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-sort text-muted"></i>
                                    }
                                </a>
                            </th>
                            <th>
                                <a href="@Url.Action("Index", new { pageNumber = Model.PageNumber, pageSize = Model.PageSize, search = Model.Search, sortBy = "city", sortDirection = currentSort == "city" && currentDirection == "asc" ? "desc" : "asc" })" class="text-decoration-none text-dark">
                                    Location
                                    @if (currentSort == "city")
                                    {
                                        <i class="fas fa-sort-@(currentDirection == "asc" ? "up" : "down")"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-sort text-muted"></i>
                                    }
                                </a>
                            </th>
                            <th>Contact</th>
                            <th>Guards</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var site in Model.Items)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@site.SiteCode</span></td>
                                <td><div class="fw-semibold">@site.SiteName</div></td>
                                <td>@site.ClientName</td>
                                <td>
                                    <small>@site.City, @site.State</small><br />
                                    <small class="text-muted">@site.PinCode</small>
                                </td>
                                <td>
                                    <small>@site.ContactPerson</small><br />
                                    <small class="text-muted">@site.ContactPhone</small>
                                </td>
                                <td>
                                    <span class="badge bg-info">
                                        <i class="fas fa-user-shield me-1"></i>@site.GuardCount
                                    </span>
                                </td>
                                <td>
                                    @if (site.IsActive)
                                    {
                                        <span class="badge bg-success"><i class="fas fa-check-circle me-1"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="fas fa-times-circle me-1"></i>Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <button type="button" class="btn btn-sm btn-outline-info" title="Generate Report" data-site-id="@site.Id" data-bs-toggle="modal" data-bs-target="#generateReportModal">
                                            <i class="fas fa-file-alt"></i>
                                        </button>
                                        <a class="btn btn-sm btn-outline-primary" title="Rate Management" href="@Url.Action("Index", "SiteRates", new { siteId = site.Id })">
                                            <i class="fas fa-rupee-sign"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = site.Id })" class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" class="d-inline" data-confirm-message="Are you sure you want to delete this site?">
                                            <input type="hidden" name="id" value="@site.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (Model.PageNumber > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { pageNumber = Model.PageNumber - 1, pageSize = Model.PageSize, search = Model.Search, sortBy = Model.SortBy, sortDirection = Model.SortDirection })">
                                    <i class="fas fa-chevron-left"></i> Previous
                                </a>
                            </li>
                        }
                        @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { pageNumber = i, pageSize = Model.PageSize, search = Model.Search, sortBy = Model.SortBy, sortDirection = Model.SortDirection })">@i</a>
                            </li>
                        }
                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { pageNumber = Model.PageNumber + 1, pageSize = Model.PageSize, search = Model.Search, sortBy = Model.SortBy, sortDirection = Model.SortDirection })">
                                    Next <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-building fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No sites found</h5>
                @if (!string.IsNullOrEmpty(Model?.Search))
                {
                    <p class="text-muted">No results found for "@Model.Search"</p>
                }
                <a href="@Url.Action("Create")" class="btn btn-primary mt-3">
                    <i class="fas fa-building me-2"></i>Add New Site
                </a>
            </div>
        }
    </div>
</div>

<!-- Generate Report Modal (for Index page) -->
<div class="modal fade" id="generateReportModal" tabindex="-1" aria-labelledby="generateReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="generateReportModalLabel"><i class="fas fa-file-alt me-2"></i>Generate Monthly Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="reportSiteId" value="" />
                <div class="mb-3">
                    <label for="reportYear" class="form-label fw-semibold">Year</label>
                    <select id="reportYear" class="form-select"></select>
                </div>
                <div class="mb-3">
                    <label for="reportMonth" class="form-label fw-semibold">Month</label>
                    <select id="reportMonth" class="form-select">
                        <option value="1">January</option>
                        <option value="2">February</option>
                        <option value="3">March</option>
                        <option value="4">April</option>
                        <option value="5">May</option>
                        <option value="6">June</option>
                        <option value="7">July</option>
                        <option value="8">August</option>
                        <option value="9">September</option>
                        <option value="10">October</option>
                        <option value="11">November</option>
                        <option value="12">December</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label for="reportFormat" class="form-label fw-semibold">Format</label>
                    <select id="reportFormat" class="form-select">
                        <option value="Excel">Excel</option>
                        <option value="PDF">PDF</option>
                    </select>
                </div>
                <div id="reportTracking" class="alert alert-secondary d-none">
                    <div class="fw-semibold mb-1">Tracking</div>
                    <div class="small">Bill ID: <span id="trackBillId">-</span></div>
                    <div class="small">Wage ID: <span id="trackWageId">-</span></div>
                </div>
                <div id="reportMessage" class="alert d-none mb-0" role="alert"></div>
            </div>
            <div class="modal-footer flex-wrap">
                <button type="button" class="btn btn-primary report-btn" data-report-type="bill"><i class="fas fa-file-invoice-dollar me-1"></i>Generate Bill</button>
                <button type="button" class="btn btn-primary report-btn" data-report-type="attendance"><i class="fas fa-clipboard-list me-1"></i>Generate Attendance</button>
                <button type="button" class="btn btn-primary report-btn" data-report-type="wages"><i class="fas fa-money-bill-wave me-1"></i>Generate Wages</button>
                <button type="button" class="btn btn-success report-btn" data-report-type="full"><i class="fas fa-file-archive me-1"></i>Generate All</button>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    function changePageSize(size) {
        const url = new URL(window.location.href);
        url.searchParams.set('pageSize', size);
        url.searchParams.set('pageNumber', '1');
        window.location.href = url.toString();
    }

    (function () {
        var modalEl = document.getElementById('generateReportModal');
        if (!modalEl) return;
        var yearSelect = document.getElementById('reportYear');
        var curYear = new Date().getFullYear();
        var curMonth = new Date().getMonth() + 1;
        for (var y = curYear; y >= curYear - 5; y--) {
            var opt = document.createElement('option');
            opt.value = y;
            opt.textContent = y;
            if (y === curYear) opt.selected = true;
            yearSelect.appendChild(opt);
        }
        document.getElementById('reportMonth').value = curMonth;

        modalEl.addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            if (btn && btn.getAttribute('data-site-id'))
                document.getElementById('reportSiteId').value = btn.getAttribute('data-site-id');
        });

        document.querySelectorAll('.report-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var siteId = document.getElementById('reportSiteId').value;
                if (!siteId) { alert('Please select a site first.'); return; }
                var year = document.getElementById('reportYear').value;
                var month = document.getElementById('reportMonth').value;
                var format = document.getElementById('reportFormat').value;
                var reportType = btn.getAttribute('data-report-type');
                var msgEl = document.getElementById('reportMessage');
                var trackingEl = document.getElementById('reportTracking');
                var trackBillIdEl = document.getElementById('trackBillId');
                var trackWageIdEl = document.getElementById('trackWageId');
                msgEl.classList.add('d-none');
                if (trackingEl) trackingEl.classList.add('d-none');
                var url = '@(Url.Content("~/Sites/DownloadReport"))?siteId=' + encodeURIComponent(siteId) + '&year=' + encodeURIComponent(year) + '&month=' + encodeURIComponent(month) + '&format=' + encodeURIComponent(format) + '&reportType=' + encodeURIComponent(reportType);
                var trackingUrl = '@(Url.Content("~/Sites/GenerateMonthlyTracking"))?siteId=' + encodeURIComponent(siteId) + '&year=' + encodeURIComponent(year) + '&month=' + encodeURIComponent(month);
                btn.disabled = true;
                var ensureTracking = (reportType === 'full')
                    ? fetch(trackingUrl, { credentials: 'include' })
                        .then(function (r) { if (!r.ok) return r.text().then(function (t) { throw new Error(t || r.statusText); }); return r.json(); })
                        .then(function (data) {
                            if (trackingEl && trackBillIdEl && trackWageIdEl) {
                                trackBillIdEl.textContent = data.billId || '-';
                                trackWageIdEl.textContent = data.wageId || '-';
                                trackingEl.classList.remove('d-none');
                            }
                        })
                    : Promise.resolve();

                ensureTracking.then(function () {
                    return fetch(url, { credentials: 'include' });
                })
                    .then(function (response) {
                        if (!response.ok) return response.text().then(function (t) { throw new Error(t || response.statusText); });
                        var cd = response.headers.get('Content-Disposition');
                        var fileName = 'report';
                        if (cd) {
                            var m = cd.match(/filename\*?=(?:UTF-8'')?"?([^";\n]+)"?/i) || cd.match(/filename="?([^";\n]+)"?/i);
                            if (m && m[1]) fileName = m[1].trim().replace(/^["']|["']$/g, '');
                        }
                        return response.blob().then(function (blob) {
                            var a = document.createElement('a');
                            a.href = URL.createObjectURL(blob);
                            a.download = fileName;
                            document.body.appendChild(a);
                            a.click();
                            document.body.removeChild(a);
                            URL.revokeObjectURL(a.href);
                        });
                    })
                    .then(function () {
                        if (msgEl) {
                            msgEl.classList.remove('d-none', 'alert-danger');
                            msgEl.classList.add('alert-success');
                            msgEl.textContent = 'Report downloaded successfully.';
                        }
                    })
                    .catch(function (err) {
                        if (msgEl) {
                            msgEl.classList.remove('d-none', 'alert-success');
                            msgEl.classList.add('alert-danger');
                            msgEl.textContent = (err && err.message) ? err.message : 'Download failed.';
                        }
                    })
                    .finally(function () { btn.disabled = false; });
            });
        });
    })();
</script>
