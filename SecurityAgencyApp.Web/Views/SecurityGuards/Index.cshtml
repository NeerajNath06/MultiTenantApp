@{
    ViewData["Title"] = "Security Guards";
    var supervisorId = ViewBag.SupervisorId;
}

<div id="securityGuardsIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-details-base="@Url.Action("Details", new { id = "__id__" })"
     data-edit-base="@Url.Action("Edit", new { id = "__id__" })"
     data-supervisor-id="@supervisorId">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Security Guards</h1>
            <p class="page-subtitle mb-0">Manage security guards</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-user-shield me-2"></i>Add New Guard
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Guards</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Guards</div>
                <div class="stat-value" data-stat="active">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Supervisor Mapped</div>
                <div class="stat-value" data-stat="supervisors">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search & Filters</h5>
    </div>
    <div class="card-body">
        <form id="securityGuardsFilterForm" class="row g-3">
            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="10" />
            <input type="hidden" id="securityGuardsSortBy" name="sortBy" value="" />
            <input type="hidden" id="securityGuardsSortDirection" name="sortDirection" value="asc" />
            <div class="col-md-10">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" id="securityGuardsSearch" name="search" class="form-control" placeholder="Search by name, code, email, or phone..." />
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-2"></i>Search
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-user-shield me-2 text-primary"></i>Guard Directory</h5>
        <span id="securityGuardsRecordCount" class="text-muted small">0 total records</span>
    </div>
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div id="securityGuardsPaginationSummaryTop" class="text-muted"></div>
            <div>
                <select id="securityGuardsPageSize" class="form-select form-select-sm d-inline-block" style="width: auto;">
                    <option value="10">10 per page</option>
                    <option value="25">25 per page</option>
                    <option value="50">50 per page</option>
                    <option value="100">100 per page</option>
                </select>
            </div>
        </div>
        <div id="securityGuardsTableWrapper"></div>
        <div id="securityGuardsPaginationContainer" class="mt-4 d-none">
            <div id="securityGuardsPaginationSummary" class="text-muted text-center small mb-2"></div>
            <ul id="securityGuardsPagination" class="pagination justify-content-center"></ul>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/security-guards/index.js" asp-append-version="true"></script>
}
