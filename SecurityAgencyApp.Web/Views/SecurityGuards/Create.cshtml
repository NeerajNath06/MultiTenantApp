@model SecurityAgencyApp.Model.Api.CreateGuardRequest
@{
    ViewData["Title"] = "Create Security Guard";
}
<div class="page-header">
    <h1 class="page-title">Create Security Guard</h1>
    <p class="page-subtitle mb-0">Add a new security guard with structured profile, contact, address, and access information.</p>
</div>

<div id="securityGuardFormPage"
     data-mode="create"
     data-submit-endpoint="SecurityGuards"
     data-redirect-url="@Url.Action("Index")">
<div class="card border-0 shadow-sm enterprise-form-card">
    <div class="card-body">
        <form id="securityGuardForm" class="form">
            <div id="securityGuardFormErrors" class="alert alert-danger mb-4 d-none" role="alert"></div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-body-tertiary py-3">
                    <h5 class="mb-0"><i class="fas fa-user me-2 text-primary"></i>Basic Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="FirstName" class="form-label">First Name <span class="text-danger">*</span></label>
                            <input asp-for="FirstName" class="form-control" required />
                            <span asp-validation-for="FirstName" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="LastName" class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input asp-for="LastName" class="form-control" required />
                            <span asp-validation-for="LastName" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="JoiningDate" class="form-label">Joining Date <span class="text-danger">*</span></label>
                            <input asp-for="JoiningDate" type="date" class="form-control" required />
                            <span asp-validation-for="JoiningDate" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="SupervisorId" class="form-label">Supervisor</label>
                            <select asp-for="SupervisorId" id="securityGuardSupervisorId" class="form-select">
                                <option value="">-- No Supervisor --</option>
                            </select>
                            <span asp-validation-for="SupervisorId" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-body-tertiary py-3">
                    <h5 class="mb-0"><i class="fas fa-address-book me-2 text-primary"></i>Contact Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="PhoneNumber" class="form-label">Phone Number <span class="text-danger">*</span></label>
                            <input asp-for="PhoneNumber" class="form-control" required />
                            <span asp-validation-for="PhoneNumber" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="EmergencyContactName" class="form-label">Emergency Contact Name <span class="text-danger">*</span></label>
                            <input asp-for="EmergencyContactName" class="form-control" required />
                            <span asp-validation-for="EmergencyContactName" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="EmergencyContactPhone" class="form-label">Emergency Contact Phone <span class="text-danger">*</span></label>
                            <input asp-for="EmergencyContactPhone" class="form-control" required />
                            <span asp-validation-for="EmergencyContactPhone" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-body-tertiary py-3">
                    <h5 class="mb-0"><i class="fas fa-id-card me-2 text-primary"></i>Personal Details</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="DateOfBirth" class="form-label">Date of Birth <span class="text-danger">*</span></label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" required />
                            <span asp-validation-for="DateOfBirth" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="Gender" class="form-label">Gender <span class="text-danger">*</span></label>
                            <select asp-for="Gender" id="securityGuardGender" class="form-select" required>
                                <option value="">-- Select --</option>
                            </select>
                            <span asp-validation-for="Gender" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="AadharNumber" class="form-label">Aadhar Number</label>
                            <input asp-for="AadharNumber" class="form-control" maxlength="12" placeholder="12-digit Aadhar" />
                            <span asp-validation-for="AadharNumber" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="PANNumber" class="form-label">PAN Number</label>
                            <input asp-for="PANNumber" class="form-control" maxlength="10" placeholder="e.g. ABCDExxxxx" />
                            <span asp-validation-for="PANNumber" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-body-tertiary py-3">
                    <h5 class="mb-0"><i class="fas fa-map-marker-alt me-2 text-primary"></i>Address Information</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Address" class="form-label">Address <span class="text-danger">*</span></label>
                            <input asp-for="Address" class="form-control" required />
                            <span asp-validation-for="Address" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="City" class="form-label">City <span class="text-danger">*</span></label>
                            <input asp-for="City" class="form-control" required />
                            <span asp-validation-for="City" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="State" class="form-label">State <span class="text-danger">*</span></label>
                            <input asp-for="State" class="form-control" required />
                            <span asp-validation-for="State" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="PinCode" class="form-label">Pin Code <span class="text-danger">*</span></label>
                            <input asp-for="PinCode" class="form-control" required />
                            <span asp-validation-for="PinCode" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-body-tertiary py-3">
                    <h5 class="mb-0"><i class="fas fa-mobile-alt me-2 text-primary"></i>Access Information</h5>
                </div>
                <div class="card-body">
                    <div class="form-check form-switch mb-3">
                        <input asp-for="CreateLoginAccount" class="form-check-input" type="checkbox" id="createLogin" />
                        <label class="form-check-label fw-semibold" for="createLogin">Create login account for mobile app</label>
                    </div>

                    <div id="loginFields" class="row g-3 @(Model.CreateLoginAccount ? string.Empty : "d-none")">
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="LoginUserName" class="form-label">Login Username / Email</label>
                            <input asp-for="LoginUserName" class="form-control" placeholder="Guard will use this to login" />
                            <span asp-validation-for="LoginUserName" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="LoginPassword" class="form-label">Password (min 6 characters)</label>
                            <input asp-for="LoginPassword" type="password" class="form-control" minlength="6" placeholder="Min 6 characters" />
                            <span asp-validation-for="LoginPassword" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-actions justify-content-end">
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
                <button type="submit" id="securityGuardFormSubmitButton" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Create Guard
                </button>
            </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/security-guards/form.js" asp-append-version="true"></script>
}
