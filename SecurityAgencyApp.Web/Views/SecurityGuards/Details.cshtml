@{
    ViewData["Title"] = "Guard Details";
    var guardId = ViewBag.GuardId;
}

<div id="securityGuardDetailsPage"
     data-guard-id="@guardId"
     data-load-endpoint="SecurityGuards/@guardId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Security Guard Details</h1>
            <p class="page-subtitle mb-0"><span data-field="fullName">-</span> - <span data-field="guardCode">-</span></p>
        </div>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Edit", new { id = guardId })" class="btn btn-warning">
                <i class="fas fa-edit me-2"></i>Edit
            </a>
            <button type="button" id="securityGuardDeleteButton" class="btn btn-danger">
                <i class="fas fa-trash me-2"></i>Delete
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm enterprise-details-card">
    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <h5 class="section-title"><i class="fas fa-user-shield"></i>Basic Info</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Guard Code</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary" data-field="guardCode">-</span></dd>
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8" data-field="fullName">-</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8" data-field="email">-</dd>
                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8" data-field="phoneNumber">-</dd>
                    <dt class="col-sm-4">Gender</dt>
                    <dd class="col-sm-8" data-field="gender">-</dd>
                    <dt class="col-sm-4">Date of Birth</dt>
                    <dd class="col-sm-8" data-field="dateOfBirth">-</dd>
                    <dt class="col-sm-4">Joining Date</dt>
                    <dd class="col-sm-8" data-field="joiningDate">-</dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary" data-field="statusBadge">-</span>
                    </dd>
                </dl>
            </div>
            <div class="col-md-6">
                <h5 class="section-title"><i class="fas fa-id-card"></i>Address &amp; ID</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8" data-field="address">-</dd>
                    <dt class="col-sm-4">City / State / Pin</dt>
                    <dd class="col-sm-8" data-field="cityStatePin">-</dd>
                    <dt class="col-sm-4">Aadhar Number</dt>
                    <dd class="col-sm-8" data-field="aadharNumber">-</dd>
                    <dt class="col-sm-4">PAN Number</dt>
                    <dd class="col-sm-8" data-field="panNumber">-</dd>
                    <dt class="col-sm-4">Emergency Contact</dt>
                    <dd class="col-sm-8" data-field="emergencyContact">-</dd>
                    <dt class="col-sm-4">Supervisor</dt>
                    <dd class="col-sm-8" data-field="supervisorName">-</dd>
                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8" data-field="createdDate">-</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/security-guards/details.js" asp-append-version="true"></script>
}
