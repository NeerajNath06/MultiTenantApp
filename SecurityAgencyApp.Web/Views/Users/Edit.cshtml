@model SecurityAgencyApp.Model.Api.UpdateUserRequest
@{
    ViewData["Title"] = "Edit User";
}

<div class="page-header">
    <h1 class="page-title">Edit User</h1>
    <p class="page-subtitle mb-0">Update user information</p>
</div>

<div id="userFormPage"
     data-mode="edit"
     data-load-endpoint="Users/@Model.Id"
     data-submit-endpoint="Users/@Model.Id"
     data-redirect-url="@Url.Action("Index")">
<div class="card border-0 shadow-sm enterprise-form-card">
    <div class="card-body">
        <form id="userForm" class="form">
            <div id="userFormErrors" class="alert alert-danger d-none" role="alert"></div>
            
            <input type="hidden" asp-for="Id" />

            <div class="form-section">
                <h5 class="section-title"><i class="fas fa-id-card"></i>Personal Information</h5>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="FirstName" class="form-label fw-semibold">First Name <span class="text-danger">*</span></label>
                        <input asp-for="FirstName" class="form-control" placeholder="Enter first name" required />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="LastName" class="form-label fw-semibold">Last Name <span class="text-danger">*</span></label>
                        <input asp-for="LastName" class="form-control" placeholder="Enter last name" required />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-12 col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="Enter email" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5 class="section-title"><i class="fas fa-address-card"></i>ID & Employment</h5>
                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label asp-for="AadharNumber" class="form-label fw-semibold">Aadhar Number</label>
                        <input asp-for="AadharNumber" class="form-control" maxlength="12" placeholder="12-digit Aadhar" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="PANNumber" class="form-label fw-semibold">PAN Number</label>
                        <input asp-for="PANNumber" class="form-control" maxlength="10" placeholder="e.g. ABCDExxxxx" />
                    </div>
                    <div class="col-12 col-md-4">
                        <label asp-for="UAN" class="form-label fw-semibold">UAN (PF/EPF)</label>
                        <input asp-for="UAN" class="form-control" maxlength="50" placeholder="Universal Account Number" />
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-12 col-md-6">
                        <label asp-for="DepartmentId" class="form-label fw-semibold">Department</label>
                        <select asp-for="DepartmentId" id="userDepartmentId" class="form-select">
                            <option value="">-- Select Department --</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="DesignationId" class="form-label fw-semibold">Designation</label>
                        <select asp-for="DesignationId" id="userDesignationId" class="form-select">
                            <option value="">-- Select Designation --</option>
                        </select>
                        <span asp-validation-for="DesignationId" class="text-danger small"></span>
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-12 col-md-6">
                        <div class="form-check">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <h5 class="section-title"><i class="fas fa-user-shield"></i>Roles</h5>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Assign Roles</label>
                        <p class="text-muted small mb-2">Assign roles (e.g. <strong>Supervisor</strong> to allow managing assigned guards).</p>
                        <div id="userRolesContainer" class="d-flex flex-wrap gap-3"></div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" id="userFormSubmitButton" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Update User
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/users/form.js" asp-append-version="true"></script>
}
