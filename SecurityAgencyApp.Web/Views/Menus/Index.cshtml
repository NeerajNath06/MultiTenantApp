@model SecurityAgencyApp.Model.Api.MenuListResponse
@{
    ViewData["Title"] = "Menus Management";
    var currentSort = Context.Request.Query["sortBy"].ToString();
    var currentDirection = string.IsNullOrWhiteSpace(Context.Request.Query["sortDirection"]) ? "asc" : Context.Request.Query["sortDirection"].ToString();
    var currentSearch = Context.Request.Query["search"].ToString();
    var currentPageSize = string.IsNullOrWhiteSpace(Context.Request.Query["pageSize"]) ? "10" : Context.Request.Query["pageSize"].ToString();
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Menus</h1>
            <p class="page-subtitle mb-0">Manage navigation menus and submenus</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-list me-2"></i>Add New Menu
        </a>
    </div>
</div>

<div class="row g-3 mb-4" id="menusStats">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Menus</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Active Menus</div>
                <div class="stat-value" data-stat="active">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Submenu Links</div>
                <div class="stat-value" data-stat="submenus">0</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search & Filters</h5>
    </div>
    <div class="card-body">
        <form method="get" class="row g-3" id="menusFilterForm">
            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="@currentPageSize" />
            <input type="hidden" name="sortBy" value="@currentSort" />
            <input type="hidden" name="sortDirection" value="@currentDirection" />
            <div class="col-md-10">
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" name="search" class="form-control" placeholder="Search by name, route..." value="@currentSearch" />
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-2"></i>Search
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden" id="menusIndexPage"
     data-index-url="@Url.Action("Index", "Menus")"
     data-submenu-create-base="@Url.Action("Create", "SubMenus", new { menuId = "__id__" })"
     data-submenu-index-base="@Url.Action("Index", "SubMenus", new { menuId = "__id__" })">
    <div class="card-header bg-body-tertiary py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="fas fa-list me-2 text-primary"></i>Menu Directory</h5>
        <span class="text-muted small" id="menusRecordCount">0 total records</span>
    </div>
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <div>
                <span class="text-muted" id="menusShowingSummary">Loading menus...</span>
            </div>
            <div>
                <select class="form-select form-select-sm d-inline-block" style="width: auto;" id="menusPageSize">
                    <option value="10" selected="@(currentPageSize == "10")">10 per page</option>
                    <option value="25" selected="@(currentPageSize == "25")">25 per page</option>
                    <option value="50" selected="@(currentPageSize == "50")">50 per page</option>
                    <option value="100" selected="@(currentPageSize == "100")">100 per page</option>
                </select>
            </div>
        </div>
        <div id="menusTableWrapper">
            <div class="text-center py-5">
                <i class="fas fa-list fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">Loading menus...</h5>
                <p class="text-muted">Fetching latest data from API.</p>
            </div>
        </div>
        <nav aria-label="Page navigation" class="mt-4 d-none" id="menusPaginationContainer">
            <div class="text-center text-muted mb-2" id="menusPaginationSummary"></div>
            <ul class="pagination justify-content-center" id="menusPagination"></ul>
        </nav>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/menus/index.js" asp-append-version="true"></script>
}
