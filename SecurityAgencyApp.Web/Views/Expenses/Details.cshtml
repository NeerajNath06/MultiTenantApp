@{
    ViewData["Title"] = "Expense Details";
}

<div id="expenseDetailsPage"
     data-expense-id="@ViewBag.ExpenseId"
     data-load-endpoint="Expenses/@ViewBag.ExpenseId"
     data-index-url="@Url.Action("Index")">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Expense Details</h1>
            <p class="page-subtitle mb-0" data-field="expenseNumber">-</p>
        </div>
        <div>
            <button id="expenseDeleteButton" type="button" class="btn btn-outline-danger">
                <i class="fas fa-trash me-2"></i>Delete
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm enterprise-details-card">
    <div class="card-body">
        <h5 class="section-title"><i class="fas fa-receipt"></i>Expense Information</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Expense Number</label>
                <p class="mb-0"><strong data-field="expenseNumber">-</strong></p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Date</label>
                <p class="mb-0" data-field="expenseDate">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Category</label>
                <p class="mb-0" data-field="category">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Status</label>
                <p class="mb-0">
                    <span data-field="statusBadge" class="badge bg-secondary">-</span>
                </p>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold text-muted">Description</label>
                <p class="mb-0" data-field="description">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Amount</label>
                <p class="mb-0"><strong class="text-success" data-field="amount">-</strong></p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Payment Method</label>
                <p class="mb-0" data-field="paymentMethod">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Vendor</label>
                <p class="mb-0" data-field="vendorName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Receipt Number</label>
                <p class="mb-0" data-field="receiptNumber">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Site</label>
                <p class="mb-0" data-field="siteName">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Guard</label>
                <p class="mb-0" data-field="guardName">-</p>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold text-muted">Notes</label>
                <p class="mb-0" data-field="notes">-</p>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Created Date</label>
                <p class="mb-0" data-field="createdDate">-</p>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/expenses/details.js" asp-append-version="true"></script>
}
