@model SecurityAgencyApp.Model.Api.CreateExpenseRequest
@{
    ViewData["Title"] = "Add Expense";
}

<div class="page-header">
    <h1 class="page-title">Add Expense</h1>
    <p class="page-subtitle mb-0">Record a new expense</p>
</div>

<div class="card border-0 shadow-sm enterprise-form-card">
    <div class="card-body">
        <div id="expenseFormPage"
             data-mode="create"
             data-submit-endpoint="Expenses"
             data-redirect-url="@Url.Action("Index")">
        <form id="expenseForm" class="form">
            <div id="expenseFormErrors" class="alert alert-danger d-none"></div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="ExpenseNumber" class="form-label fw-semibold">Expense Number <span class="text-danger">*</span></label>
                    <input asp-for="ExpenseNumber" class="form-control" required />
                    <span asp-validation-for="ExpenseNumber" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ExpenseDate" class="form-label fw-semibold">Expense Date <span class="text-danger">*</span></label>
                    <input asp-for="ExpenseDate" type="date" class="form-control" required />
                    <span asp-validation-for="ExpenseDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="Category" class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
                    <select asp-for="Category" class="form-select" required>
                        <option value="">Select Category</option>
                        <option value="Travel">Travel</option>
                        <option value="Equipment">Equipment</option>
                        <option value="Training">Training</option>
                        <option value="Maintenance">Maintenance</option>
                        <option value="Office">Office</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="Category" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Amount" class="form-label fw-semibold">Amount <span class="text-danger">*</span></label>
                    <input asp-for="Amount" type="number" step="0.01" class="form-control" required />
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="SiteId" class="form-label fw-semibold">Site (Optional)</label>
                    <select id="expenseSiteId" asp-for="SiteId" class="form-select">
                        <option value="">Select Site</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="GuardId" class="form-label fw-semibold">Guard (Optional)</label>
                    <select id="expenseGuardId" asp-for="GuardId" class="form-select">
                        <option value="">Select Guard</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="PaymentMethod" class="form-label fw-semibold">Payment Method</label>
                    <select asp-for="PaymentMethod" class="form-select">
                        <option value="Cash">Cash</option>
                        <option value="Cheque">Cheque</option>
                        <option value="BankTransfer">Bank Transfer</option>
                        <option value="UPI">UPI</option>
                        <option value="CreditCard">Credit Card</option>
                    </select>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label asp-for="VendorName" class="form-label fw-semibold">Vendor Name</label>
                    <input asp-for="VendorName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ReceiptNumber" class="form-label fw-semibold">Receipt Number</label>
                    <input asp-for="ReceiptNumber" class="form-control" />
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
            </div>

            <div class="form-actions">
                <button id="expenseFormSubmitButton" type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Add Expense
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="fas fa-times me-2"></i>Cancel
                </a>
            </div>
        </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/pages/expenses/form.js" asp-append-version="true"></script>
}
