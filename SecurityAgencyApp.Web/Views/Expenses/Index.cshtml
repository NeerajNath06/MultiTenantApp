@{
    ViewData["Title"] = "Expenses Management";
}

<div id="expensesIndexPage"
     data-index-url="@Url.Action("Index")"
     data-create-url="@Url.Action("Create")"
     data-details-base="@Url.Action("Details", new { id = "__id__" })">
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">Expenses</h1>
            <p class="page-subtitle mb-0">Track agency expenses</p>
        </div>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="fas fa-receipt me-2"></i>Add Expense
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Total Expenses</div>
                <div class="stat-value" data-stat="total">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Approved</div>
                <div class="stat-value" data-stat="approved">0</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="stat-label">Visible Amount</div>
                <div class="stat-value" data-stat="amount">Rs 0.00</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-body-tertiary py-3">
        <h5 class="mb-0"><i class="fas fa-filter me-2 text-primary"></i>Search & Filters</h5>
    </div>
    <form id="expensesFilterForm" method="get" action="@Url.Action("Index")" class="table-toolbar">
        <div class="search-wrap">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                <input type="text" name="search" class="form-control border-start-0" placeholder="Search by expense number or description..." value="@Context.Request.Query["search"]" />
            </div>
        </div>
        <select name="category" class="form-select form-select-sm" style="max-width: 180px;">
            <option value="">All Categories</option>
            <option value="Travel">Travel</option>
            <option value="Equipment">Equipment</option>
            <option value="Training">Training</option>
            <option value="Maintenance">Maintenance</option>
            <option value="Office">Office</option>
            <option value="Other">Other</option>
        </select>
        <select name="status" class="form-select form-select-sm" style="max-width: 180px;">
            <option value="">All Statuses</option>
            <option value="Pending">Pending</option>
            <option value="Approved">Approved</option>
            <option value="Paid">Paid</option>
            <option value="Rejected">Rejected</option>
        </select>
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="fas fa-filter me-1"></i>Apply
        </button>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Clear</a>
    </form>
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h5 class="mb-0"><i class="fas fa-receipt me-2 text-primary"></i>Expense Directory</h5>
            <span id="expensesRecordCount" class="text-muted small">0 total records</span>
        </div>
        <div id="expensesTableWrapper"></div>
        <div id="expensesPaginationContainer" class="d-none mt-4">
            <div id="expensesPaginationSummary" class="text-muted small mb-2"></div>
            <ul id="expensesPagination" class="pagination justify-content-center mb-0"></ul>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <script src="~/js/pages/expenses/index.js" asp-append-version="true"></script>
}
